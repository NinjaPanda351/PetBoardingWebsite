@{
    Layout = null;
    ViewBag.Title = "Thank you";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Thank you &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
        @@keyframes ppPop { 0% { opacity: 0; transform: scale(0.85); } 60% { transform: scale(1.06); } 100% { opacity: 1; transform: scale(1); } }
    </style>
</head>
<body>
<div style="min-height: 100vh; display: flex; flex-direction: column; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">

    <header style="position: sticky; top: 0; z-index: 40; background: rgba(255,255,255,0.86); backdrop-filter: blur(10px); border-bottom: 1px solid #e7e6ee;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 14px 28px; display: flex; align-items: center; gap: 28px;">
            <a href="@Url.Action("Index", "Home")" style="display: flex; align-items: center; gap: 11px; text-decoration: none;">
                <span style="width: 38px; height: 38px; border-radius: 12px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 19px; box-shadow: 0 4px 12px -3px var(--accent);">&#x1F43E;</span>
                <span style="text-align: left; line-height: 1.05;">
                    <span style="display: block; font-family: Newsreader, serif; font-size: 18px; font-weight: 600; color: #2b2f3a;">Pawesome Palace</span>
                    <span style="display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #9a9eaa; font-weight: 600;">Pet Boarding</span>
                </span>
            </a>
            <nav style="display: flex; gap: 22px; margin-left: 14px;">
                <a href="@Url.Action("Index", "Home")#services" style="color: #6a6f7d; text-decoration: none; font-size: 14px; font-weight: 600;">Services</a>
                <a href="@Url.Action("Index", "Home")#how" style="color: #6a6f7d; text-decoration: none; font-size: 14px; font-weight: 600;">How it works</a>
                <a href="@Url.Action("Index", "Home")#contact" style="color: #6a6f7d; text-decoration: none; font-size: 14px; font-weight: 600;">Contact</a>
            </nav>
            <div style="margin-left: auto; display: flex; align-items: center; gap: 10px;">
                <a href="@Url.Action("Login", "Account")" style="padding: 9px 16px; border-radius: 10px; background: none; color: #2b2f3a; font-weight: 700; font-size: 14px; text-decoration: none;">Sign in</a>
                <a href="@Url.Action("Register", "Account")" style="padding: 9px 18px; border-radius: 10px; background: var(--accent); color: #fff; font-weight: 700; font-size: 14px; text-decoration: none;">Get started</a>
            </div>
        </div>
    </header>

    <main style="flex: 1; display: grid; place-items: center; padding: 80px 28px; background: linear-gradient(170deg, var(--accent-soft), #f3f4f8 65%);">
        <div style="width: 100%; max-width: 560px; text-align: center; animation: ppFade 0.4s ease both;">

            <div style="animation: ppPop 0.5s cubic-bezier(.34,1.56,.64,1) both; animation-delay: 0.1s;">
                <span style="width: 88px; height: 88px; border-radius: 26px; background: #edf5ee; display: grid; place-items: center; font-size: 42px; margin: 0 auto; box-shadow: 0 8px 28px -10px rgba(40,40,70,0.15);">&#x1F43E;</span>
            </div>

            <h1 style="margin: 28px 0 12px; font-family: Newsreader, serif; font-size: 44px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.05; color: #2b2f3a;">Thank you for reaching out!</h1>
            <p style="margin: 0 0 32px; font-size: 17px; line-height: 1.65; color: #5a5f6d; max-width: 440px; margin-left: auto; margin-right: auto;">We've received your message and one of our team members will get back to you within <strong style="color: #2b2f3a;">24 hours</strong>. In the meantime, feel free to explore what we offer.</p>

            <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 20px; padding: 28px 32px; box-shadow: 0 2px 8px rgba(40,40,70,0.05); text-align: left; margin-bottom: 32px;">
                <p style="margin: 0 0 18px; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-ink);">What happens next</p>
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    <div style="display: flex; align-items: flex-start; gap: 14px;">
                        <span style="width: 36px; height: 36px; border-radius: 10px; background: var(--accent-soft); color: var(--accent-ink); display: grid; place-items: center; font-family: Newsreader, serif; font-size: 17px; font-weight: 600; flex-shrink: 0;">1</span>
                        <div>
                            <p style="margin: 0 0 3px; font-size: 14px; font-weight: 700; color: #2b2f3a;">We review your message</p>
                            <p style="margin: 0; font-size: 13px; color: #6a6f7d; line-height: 1.5;">Our team reads every enquiry carefully and routes it to the right person.</p>
                        </div>
                    </div>
                    <div style="display: flex; align-items: flex-start; gap: 14px;">
                        <span style="width: 36px; height: 36px; border-radius: 10px; background: var(--accent-soft); color: var(--accent-ink); display: grid; place-items: center; font-family: Newsreader, serif; font-size: 17px; font-weight: 600; flex-shrink: 0;">2</span>
                        <div>
                            <p style="margin: 0 0 3px; font-size: 14px; font-weight: 700; color: #2b2f3a;">You'll hear from us within 24 hours</p>
                            <p style="margin: 0; font-size: 13px; color: #6a6f7d; line-height: 1.5;">Check your inbox -- we'll reply with answers, availability, or next steps.</p>
                        </div>
                    </div>
                    <div style="display: flex; align-items: flex-start; gap: 14px;">
                        <span style="width: 36px; height: 36px; border-radius: 10px; background: var(--accent-soft); color: var(--accent-ink); display: grid; place-items: center; font-family: Newsreader, serif; font-size: 17px; font-weight: 600; flex-shrink: 0;">3</span>
                        <div>
                            <p style="margin: 0 0 3px; font-size: 14px; font-weight: 700; color: #2b2f3a;">Book your pet's stay</p>
                            <p style="margin: 0; font-size: 13px; color: #6a6f7d; line-height: 1.5;">Once we've sorted everything out, create an account and book in minutes.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
                <a href="@Url.Action("Register", "Account")" style="padding: 13px 26px; border-radius: 12px; background: var(--accent); color: #fff; font-weight: 700; font-size: 15px; text-decoration: none;">Create an account</a>
                <a href="@Url.Action("Index", "Home")" style="padding: 13px 24px; border-radius: 12px; border: 1px solid #dcdbe6; background: #fff; color: #2b2f3a; font-weight: 700; font-size: 15px; text-decoration: none;">Back to home</a>
            </div>

            <p style="margin: 32px 0 0; font-size: 13px; color: #9a9eaa;">Can't wait? Call us at <a href="tel:+14155557297" style="color: var(--accent-ink); font-weight: 700; text-decoration: none;">(415) 555-7297</a> &middot; Every day 7am - 8pm</p>

        </div>
    </main>

    <footer style="background: #2b2f3a;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 40px 28px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 11px;">
                <span style="width: 36px; height: 36px; border-radius: 11px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 18px;">&#x1F43E;</span>
                <span style="font-family: Newsreader, serif; font-size: 17px; font-weight: 600; color: #fff;">Pawesome Palace</span>
            </div>
            <span style="margin-left: auto; font-size: 13px; color: #8a8fa0;">&copy; @DateTime.Now.Year Pawesome Palace Pet Boarding. Made with care.</span>
        </div>
    </footer>

</div>
</body>
</html>
