<script>
    (function () {
        // Slideshow
        var imgs = document.querySelectorAll('.pp-hero-slideshow img');
        if (imgs.length) {
            var idx = 0;
            setInterval(function () {
                imgs[idx].classList.remove('active');
                idx = (idx + 1) % imgs.length;
                imgs[idx].classList.add('active');
            }, 3500);
        }

        // FAQ accordion
        document.querySelectorAll('.pp-faq-q').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var item = this.closest('.pp-faq-item');
                var isOpen = item.classList.contains('open');
                document.querySelectorAll('.pp-faq-item.open').forEach(function (el) {
                    el.classList.remove('open');
                });
                if (!isOpen) item.classList.add('open');
            });
        });

        // Active nav highlight on scroll
        var sections = document.querySelectorAll('section[id], div[id]');
        var navLinks = document.querySelectorAll('.pp-nav a');
        window.addEventListener('scroll', function () {
            var scrollY = window.scrollY + 100;
            sections.forEach(function (sec) {
                if (scrollY >= sec.offsetTop && scrollY < sec.offsetTop + sec.offsetHeight) {
                    navLinks.forEach(function (a) {
                        a.style.color = a.getAttribute('href') === '#' + sec.id ? 'var(--accent-ink)' : '';
                    });
                }
            });
        });
    })();
</script>
