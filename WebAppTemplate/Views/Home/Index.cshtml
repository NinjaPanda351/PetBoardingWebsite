@{
    ViewData["Title"] = "Pawesome Palace — Pet Boarding";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            --accent: #6b7fd1;
            --accent-soft: #eef0fb;
            --accent-ink: #41509a;
            font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
            color: #2b2f3a;
            background: #f3f4f8;
            -webkit-font-smoothing: antialiased;
            margin: 0;
            padding: 0;
        }

        ::placeholder {
            color: #aeb2bd;
        }

        @@keyframes ppFade {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: none;
            }
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-soft);
        }

        /* Header */
        .pp-header {
            position: sticky;
            top: 0;
            z-index: 40;
            background: rgba(255,255,255,0.86);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #e7e6ee;
        }

        .pp-header-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 14px 28px;
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .pp-logo-btn {
            display: flex;
            align-items: center;
            gap: 11px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
        }

        .pp-logo-icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            background: var(--accent);
            color: #fff;
            display: grid;
            place-items: center;
            font-size: 19px;
            box-shadow: 0 4px 12px -3px var(--accent);
        }

        .pp-logo-text {
            text-align: left;
            line-height: 1.05;
        }

        .pp-logo-name {
            display: block;
            font-family: Newsreader, serif;
            font-size: 18px;
            font-weight: 600;
            color: #2b2f3a;
        }

        .pp-logo-sub {
            display: block;
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #9a9eaa;
            font-weight: 600;
        }

        .pp-nav {
            display: flex;
            gap: 22px;
            margin-left: 14px;
        }

            .pp-nav a {
                color: #6a6f7d;
                text-decoration: none;
                font-size: 14px;
                font-weight: 600;
            }

                .pp-nav a:hover {
                    color: var(--accent-ink);
                }

        .pp-header-actions {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pp-btn-ghost {
            padding: 9px 16px;
            border-radius: 10px;
            border: none;
            background: none;
            color: #2b2f3a;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            font-family: inherit;
            text-decoration: none;
        }

        .pp-btn-accent {
            padding: 9px 18px;
            border-radius: 10px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            font-family: inherit;
            text-decoration: none;
        }

        /* Hero */
        .pp-hero {
            background: linear-gradient(170deg, var(--accent-soft), #f3f4f8 70%);
        }

        .pp-hero-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 72px 28px 80px;
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            gap: 56px;
            align-items: center;
        }

        .pp-hero-copy {
            animation: ppFade 0.4s ease both;
        }

        .pp-hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--accent-ink);
            background: #fff;
            padding: 7px 14px;
            border-radius: 20px;
            box-shadow: 0 1px 2px rgba(40,40,70,0.05);
        }

        .pp-hero-h1 {
            margin: 20px 0 0;
            font-family: Newsreader, serif;
            font-size: 54px;
            line-height: 1.05;
            font-weight: 500;
            letter-spacing: -0.02em;
            color: #2b2f3a;
            text-wrap: balance;
        }

        .pp-hero-lead {
            margin: 22px 0 0;
            font-size: 18px;
            line-height: 1.6;
            color: #5a5f6d;
            max-width: 480px;
        }

        .pp-hero-ctas {
            margin-top: 30px;
            display: flex;
            gap: 12px;
        }

        .pp-btn-primary {
            padding: 14px 26px;
            border-radius: 12px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            font-family: inherit;
        }

        .pp-btn-outline {
            padding: 14px 24px;
            border-radius: 12px;
            border: 1px solid #dcdbe6;
            background: #fff;
            color: #2b2f3a;
            font-weight: 700;
            font-size: 15px;
            text-decoration: none;
        }

        .pp-hero-trust {
            margin-top: 30px;
            display: flex;
            gap: 26px;
        }

            .pp-hero-trust span {
                font-size: 13px;
                color: #6a6f7d;
                font-weight: 600;
            }

        .pp-hero-visual {
            position: relative;
            animation: ppFade 0.5s ease both;
        }

        .pp-hero-img-placeholder {
            aspect-ratio: 4/5;
            border-radius: 24px;
            background: repeating-linear-gradient(45deg, #e7eaf6, #e7eaf6 13px, #eef0f8 13px, #eef0f8 26px);
            border: 1px solid #e2e3f0;
            display: grid;
            place-items: center;
        }

            .pp-hero-img-placeholder span {
                font-family: ui-monospace, monospace;
                font-size: 13px;
                color: #9a9eaa;
                background: #fff;
                padding: 8px 14px;
                border-radius: 8px;
            }

        .pp-hero-checkin {
            position: absolute;
            bottom: 22px;
            left: -18px;
            background: #fff;
            border-radius: 16px;
            padding: 14px 18px;
            box-shadow: 0 14px 30px -14px rgba(40,40,70,0.3);
            display: flex;
            align-items: center;
            gap: 11px;
        }

        .pp-hero-checkin-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #fbecdf;
            display: grid;
            place-items: center;
            font-size: 20px;
        }

        .pp-hero-checkin-text {
            line-height: 1.2;
        }

            .pp-hero-checkin-text strong {
                display: block;
                font-size: 13px;
                font-weight: 700;
            }

            .pp-hero-checkin-text span {
                display: block;
                font-size: 12px;
                color: #9a9eaa;
            }

        /* Services */
        .pp-services {
            scroll-margin-top: 80px;
            max-width: 1120px;
            margin: 0 auto;
            padding: 80px 28px;
        }

        .pp-section-label {
            margin: 0 0 8px;
            font-size: 12px;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--accent-ink);
            font-weight: 700;
        }

        .pp-section-hdr {
            text-align: center;
            max-width: 560px;
            margin: 0 auto 44px;
        }

            .pp-section-hdr h2 {
                margin: 0;
                font-family: Newsreader, serif;
                font-size: 38px;
                font-weight: 500;
                letter-spacing: -0.01em;
            }

            .pp-section-hdr p {
                margin: 14px 0 0;
                font-size: 16px;
                color: #6a6f7d;
                line-height: 1.6;
            }

        .pp-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .pp-card {
            background: #fff;
            border: 1px solid #ebeaf1;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 1px 2px rgba(40,40,70,0.04);
        }

        .pp-card-icon {
            width: 54px;
            height: 54px;
            border-radius: 16px;
            background: var(--accent-soft);
            display: grid;
            place-items: center;
            font-size: 26px;
        }

        .pp-card h3 {
            margin: 18px 0 8px;
            font-size: 19px;
            font-weight: 700;
            color: #2b2f3a;
        }

        .pp-card p {
            margin: 0;
            font-size: 14px;
            color: #6a6f7d;
            line-height: 1.6;
            min-height: 66px;
        }

        .pp-card-price {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid #f0eff5;
            display: flex;
            align-items: baseline;
            gap: 6px;
        }

            .pp-card-price .amount {
                font-family: Newsreader, serif;
                font-size: 26px;
                font-weight: 600;
                color: var(--accent-ink);
            }

            .pp-card-price .period {
                font-size: 13px;
                color: #9a9eaa;
                font-weight: 600;
            }

        /* How it works */
        .pp-how {
            scroll-margin-top: 80px;
            background: #fbfaf7;
            border-top: 1px solid #efee f4;
            border-bottom: 1px solid #efeef4;
        }

        .pp-how-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 80px 28px;
        }

        .pp-how-hdr {
            text-align: center;
            max-width: 560px;
            margin: 0 auto 48px;
        }

            .pp-how-hdr h2 {
                margin: 0;
                font-family: Newsreader, serif;
                font-size: 38px;
                font-weight: 500;
                letter-spacing: -0.01em;
            }

        .pp-steps {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .pp-step {
            text-align: center;
            padding: 0 12px;
        }

        .pp-step-num {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--accent);
            color: #fff;
            display: grid;
            place-items: center;
            font-family: Newsreader, serif;
            font-size: 22px;
            margin: 0 auto;
        }

        .pp-step h3 {
            margin: 18px 0 8px;
            font-size: 18px;
            font-weight: 700;
        }

        .pp-step p {
            margin: 0;
            font-size: 14px;
            color: #6a6f7d;
            line-height: 1.6;
        }

        /* Contact */
        .pp-contact {
            scroll-margin-top: 80px;
            max-width: 1120px;
            margin: 0 auto;
            padding: 80px 28px;
        }

        .pp-contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 48px;
            align-items: start;
        }

        .pp-contact-info h2 {
            margin: 0 0 16px;
            font-family: Newsreader, serif;
            font-size: 38px;
            font-weight: 500;
            letter-spacing: -0.01em;
        }

        .pp-contact-info > p {
            margin: 0 0 28px;
            font-size: 16px;
            color: #6a6f7d;
            line-height: 1.6;
        }

        .pp-contact-details {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .pp-contact-item {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .pp-contact-item-icon {
            width: 44px;
            height: 44px;
            border-radius: 13px;
            background: var(--accent-soft);
            display: grid;
            place-items: center;
            font-size: 19px;
            flex-shrink: 0;
        }

        .pp-contact-item-label {
            display: block;
            font-size: 12px;
            color: #9a9eaa;
            font-weight: 600;
        }

        .pp-contact-item-value {
            display: block;
            font-size: 15px;
            font-weight: 600;
        }

        .pp-contact-form {
            background: #fff;
            border: 1px solid #ebeaf1;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 1px 2px rgba(40,40,70,0.04);
        }

        .pp-form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .pp-form-field {
            display: block;
        }

            .pp-form-field + .pp-form-field,
            .pp-form-row + .pp-form-field {
                margin-top: 14px;
            }

        .pp-form-label {
            display: block;
            font-size: 12px;
            font-weight: 700;
            color: #6b7280;
            margin-bottom: 6px;
        }

        .pp-form-input,
        .pp-form-textarea {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #e4e2ec;
            border-radius: 10px;
            font: inherit;
            font-size: 14px;
            color: #2b2f3a;
        }

        .pp-form-textarea {
            resize: vertical;
        }

        .pp-btn-submit {
            margin-top: 18px;
            width: 100%;
            padding: 13px;
            border-radius: 11px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            font-family: inherit;
        }

        /* Footer */
        .pp-footer {
            background: #2b2f3a;
        }

        .pp-footer-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 40px 28px;
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .pp-footer-logo {
            display: flex;
            align-items: center;
            gap: 11px;
        }

        .pp-footer-logo-icon {
            width: 36px;
            height: 36px;
            border-radius: 11px;
            background: var(--accent);
            color: #fff;
            display: grid;
            place-items: center;
            font-size: 18px;
        }

        .pp-footer-logo-name {
            font-family: Newsreader, serif;
            font-size: 17px;
            font-weight: 600;
            color: #fff;
        }

        .pp-footer-copy {
            margin-left: auto;
            font-size: 13px;
            color: #8a8fa0;
        }
    </style>
}

<!-- ═══ HEADER ═══ -->
<header class="pp-header">
    <div class="pp-header-inner">
        <button class="pp-logo-btn" type="button">
            <span class="pp-logo-icon">🐾</span>
            <span class="pp-logo-text">
                <span class="pp-logo-name">Pawesome Palace</span>
                <span class="pp-logo-sub">Pet Boarding</span>
            </span>
        </button>
        <nav class="pp-nav">
            <a href="#services">Services</a>
            <a href="#how">How it works</a>
            <a href="#contact">Contact</a>
        </nav>
        <div class="pp-header-actions">
            <a href="@Url.Action("Login", "Account")" class="pp-btn-ghost">Sign in</a>
            <a href="@Url.Action("Register", "Account")" class="pp-btn-accent">Get Started</a>
    </div>
</header>

<!-- ═══ HERO ═══ -->
<section class="pp-hero">
    <div class="pp-hero-inner">
        <div class="pp-hero-copy">
            <span class="pp-hero-badge">🐾 Trusted by 2,000+ pet parents</span>
            <h1 class="pp-hero-h1">A home away from home for your best friend.</h1>
            <p class="pp-hero-lead">Cozy boarding, attentive daycare, and daily photo updates — so you can travel knowing they're loved and looked after.</p>
            <div class="pp-hero-ctas">
                <button class="pp-btn-primary" type="button">Book a stay</button>
                <a href="#services" class="pp-btn-outline">Explore services</a>
            </div>
            <div class="pp-hero-trust">
                <span>✓ 24/7 supervised care</span>
                <span>✓ Vet on call</span>
                <span>✓ Free cancellation</span>
            </div>
        </div>
        <div class="pp-hero-visual">
            <div class="pp-hero-img-placeholder">
                <span>hero photo · happy dog at the palace</span>
            </div>
            <div class="pp-hero-checkin">
                <span class="pp-hero-checkin-icon">🐶</span>
                <div class="pp-hero-checkin-text">
                    <strong>Biscuit checked in</strong>
                    <span>Daily updates on</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ SERVICES ═══ -->
<section id="services" class="pp-services">
    <div class="pp-section-hdr">
        <p class="pp-section-label">Our services</p>
        <h2>Care tailored to every tail</h2>
        <p>Whether it's a weekend or a long holiday, pick the stay that fits your companion best.</p>
    </div>
    <div class="pp-cards">
        <div class="pp-card">
            <span class="pp-card-icon">🏡</span>
            <h3>Standard Boarding</h3>
            <p>A cozy private kennel, daily walks, and plenty of supervised playtime.</p>
            <div class="pp-card-price">
                <span class="amount">$45</span>
                <span class="period">/ night</span>
            </div>
        </div>
        <div class="pp-card">
            <span class="pp-card-icon">🛏️</span>
            <h3>Deluxe Suite</h3>
            <p>A spacious room with a comfy bed, window view, and extra one-on-one care.</p>
            <div class="pp-card-price">
                <span class="amount">$75</span>
                <span class="period">/ night</span>
            </div>
        </div>
        <div class="pp-card">
            <span class="pp-card-icon">☀️</span>
            <h3>Daycare</h3>
            <p>Supervised group play and restful naps while you are out for the day.</p>
            <div class="pp-card-price">
                <span class="amount">$30</span>
                <span class="period">/ day</span>
            </div>
        </div>
    </div>
</section>

<!-- ═══ HOW IT WORKS ═══ -->
<section id="how" class="pp-how">
    <div class="pp-how-inner">
        <div class="pp-how-hdr">
            <p class="pp-section-label">How it works</p>
            <h2>Booking takes minutes</h2>
        </div>
        <div class="pp-steps">
            <div class="pp-step">
                <span class="pp-step-num">1</span>
                <h3>Book online</h3>
                <p>Pick your dates, choose a service, and tell us about your pet's needs.</p>
            </div>
            <div class="pp-step">
                <span class="pp-step-num">2</span>
                <h3>Drop them off</h3>
                <p>Bring your companion in — we'll handle the rest with care and daily updates.</p>
            </div>
            <div class="pp-step">
                <span class="pp-step-num">3</span>
                <h3>Relax</h3>
                <p>Enjoy your time away knowing they're playing, resting, and well cared for.</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══ CONTACT ═══ -->
<section id="contact" class="pp-contact">
    <div class="pp-contact-grid">
        <div class="pp-contact-info">
            <p class="pp-section-label">Get in touch</p>
            <h2>Come visit the palace</h2>
            <p>Questions about a stay, a tour, or your pet's special needs? We'd love to hear from you.</p>
            <div class="pp-contact-details">
                <div class="pp-contact-item">
                    <span class="pp-contact-item-icon">📍</span>
                    <span>
                        <span class="pp-contact-item-label">Visit us</span>
                        <span class="pp-contact-item-value">1429 Larkspur Lane, San Mateo, CA 94403</span>
                    </span>
                </div>
                <div class="pp-contact-item">
                    <span class="pp-contact-item-icon">📞</span>
                    <span>
                        <span class="pp-contact-item-label">Call us</span>
                        <span class="pp-contact-item-value">(415) 555-7297</span>
                    </span>
                </div>
                <div class="pp-contact-item">
                    <span class="pp-contact-item-icon">✉️</span>
                    <span>
                        <span class="pp-contact-item-label">Email us</span>
                        <span class="pp-contact-item-value">
                            <a href="mailto:hello@pawesomepalace.com">hello@@pawesomepalace.com</a>
                        </span>
                    </span>
                </div>
                <div class="pp-contact-item">
                    <span class="pp-contact-item-icon">🕘</span>
                    <span>
                        <span class="pp-contact-item-label">Hours</span>
                        <span class="pp-contact-item-value">Every day · 7:00am – 8:00pm</span>
                    </span>
                </div>
            </div>
        </div>

        <div class="pp-contact-form">
            @* Wire this up to a ContactViewModel + controller action when ready *@
            <div class="pp-form-row">
                <label class="pp-form-field">
                    <span class="pp-form-label">Name</span>
                    <input class="pp-form-input" type="text" placeholder="Jordan Avery" />
                </label>
                <label class="pp-form-field">
                    <span class="pp-form-label">Email</span>
                    <input class="pp-form-input" type="email" placeholder="you@email.com" />
                </label>
            </div>
            <label class="pp-form-field">
                <span class="pp-form-label">How can we help?</span>
                <textarea class="pp-form-textarea" rows="4" placeholder="Tell us about your pet and the dates you have in mind…"></textarea>
            </label>
            <button class="pp-btn-submit" type="button">Send message</button>
        </div>
    </div>
</section>

<!-- ═══ FOOTER ═══ -->
<footer class="pp-footer">
    <div class="pp-footer-inner">
        <div class="pp-footer-logo">
            <span class="pp-footer-logo-icon">🐾</span>
            <span class="pp-footer-logo-name">Pawesome Palace</span>
        </div>
        <span class="pp-footer-copy">© @DateTime.Now.Year Pawesome Palace Pet Boarding. Made with care.</span>
    </div>
</footer>
