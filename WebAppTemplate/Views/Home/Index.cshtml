@model PawesomePalace.ViewModels.HomeContactViewModel
@{
    ViewData["Title"] = "Pawesome Palace — Pet Boarding";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            --accent: #6b7fd1;
            --accent-soft: #eef0fb;
            --accent-ink: #41509a;
            font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
            color: #2b2f3a;
            background: #f3f4f8;
            -webkit-font-smoothing: antialiased;
            margin: 0;
            padding: 0;
        }

        ::placeholder {
            color: #aeb2bd;
        }

        @@keyframes ppFade {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: none;
            }
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-soft);
        }

        /* Header */
        .pp-header {
            position: sticky;
            top: 0;
            z-index: 40;
            background: rgba(255,255,255,0.86);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #e7e6ee;
        }

        .pp-header-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 14px 28px;
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .pp-logo-btn {
            display: flex;
            align-items: center;
            gap: 11px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
        }

        .pp-logo-icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            background: var(--accent);
            color: #fff;
            display: grid;
            place-items: center;
            font-size: 19px;
            box-shadow: 0 4px 12px -3px var(--accent);
        }

        .pp-logo-text {
            text-align: left;
            line-height: 1.05;
        }

        .pp-logo-name {
            display: block;
            font-family: Newsreader, serif;
            font-size: 18px;
            font-weight: 600;
            color: #2b2f3a;
        }

        .pp-logo-sub {
            display: block;
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #9a9eaa;
            font-weight: 600;
        }

        .pp-nav {
            display: flex;
            gap: 22px;
            margin-left: 14px;
        }

            .pp-nav a {
                color: #6a6f7d;
                text-decoration: none;
                font-size: 14px;
                font-weight: 600;
            }

                .pp-nav a:hover {
                    color: var(--accent-ink);
                }

        .pp-header-actions {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pp-btn-ghost {
            padding: 9px 16px;
            border-radius: 10px;
            border: none;
            background: none;
            color: #2b2f3a;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            font-family: inherit;
            text-decoration: none;
        }

        .pp-btn-accent {
            padding: 9px 18px;
            border-radius: 10px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            font-family: inherit;
            text-decoration: none;
        }

        /* Hero */
        .pp-hero {
            background: linear-gradient(170deg, var(--accent-soft), #f3f4f8 70%);
        }

        .pp-hero-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 72px 28px 80px;
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            gap: 56px;
            align-items: center;
        }

        .pp-hero-copy {
            animation: ppFade 0.4s ease both;
        }

        .pp-hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--accent-ink);
            background: #fff;
            padding: 7px 14px;
            border-radius: 20px;
            box-shadow: 0 1px 2px rgba(40,40,70,0.05);
        }

        .pp-hero-h1 {
            margin: 20px 0 0;
            font-family: Newsreader, serif;
            font-size: 54px;
            line-height: 1.05;
            font-weight: 500;
            letter-spacing: -0.02em;
            color: #2b2f3a;
            text-wrap: balance;
        }

        .pp-hero-lead {
            margin: 22px 0 0;
            font-size: 18px;
            line-height: 1.6;
            color: #5a5f6d;
            max-width: 480px;
        }

        .pp-hero-ctas {
            margin-top: 30px;
            display: flex;
            gap: 12px;
        }

        .pp-btn-primary {
            padding: 14px 26px;
            border-radius: 12px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            font-family: inherit;
        }

        .pp-btn-outline {
            padding: 14px 24px;
            border-radius: 12px;
            border: 1px solid #dcdbe6;
            background: #fff;
            color: #2b2f3a;
            font-weight: 700;
            font-size: 15px;
            text-decoration: none;
        }

        .pp-hero-trust {
            margin-top: 30px;
            display: flex;
            gap: 26px;
        }

            .pp-hero-trust span {
                font-size: 13px;
                color: #6a6f7d;
                font-weight: 600;
            }

        .pp-hero-visual {
            position: relative;
            animation: ppFade 0.5s ease both;
        }

        .pp-hero-slideshow {
            aspect-ratio: 4/5;
            border-radius: 24px;
            overflow: hidden;
            position: relative;
            border: 1px solid #e2e3f0;
        }

            .pp-hero-slideshow img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                opacity: 0;
                transition: opacity 0.9s ease;
            }

            .pp-hero-slideshow img.active {
                opacity: 1;
            }

            .pp-hero-img-placeholder span {
                font-family: ui-monospace, monospace;
                font-size: 13px;
                color: #9a9eaa;
                background: #fff;
                padding: 8px 14px;
                border-radius: 8px;
            }

        .pp-hero-checkin {
            position: absolute;
            bottom: 22px;
            left: -18px;
            background: #fff;
            border-radius: 16px;
            padding: 14px 18px;
            box-shadow: 0 14px 30px -14px rgba(40,40,70,0.3);
            display: flex;
            align-items: center;
            gap: 11px;
        }

        .pp-hero-checkin-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #fbecdf;
            display: grid;
            place-items: center;
            font-size: 20px;
        }

        .pp-hero-checkin-text {
            line-height: 1.2;
        }

            .pp-hero-checkin-text strong {
                display: block;
                font-size: 13px;
                font-weight: 700;
            }

            .pp-hero-checkin-text span {
                display: block;
                font-size: 12px;
                color: #9a9eaa;
            }

        /* Services */
        .pp-services {
            scroll-margin-top: 80px;
            max-width: 1120px;
            margin: 0 auto;
            padding: 80px 28px;
        }

        .pp-section-label {
            margin: 0 0 8px;
            font-size: 12px;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--accent-ink);
            font-weight: 700;
        }

        .pp-section-hdr {
            text-align: center;
            max-width: 560px;
            margin: 0 auto 44px;
        }

            .pp-section-hdr h2 {
                margin: 0;
                font-family: Newsreader, serif;
                font-size: 38px;
                font-weight: 500;
                letter-spacing: -0.01em;
            }

            .pp-section-hdr p {
                margin: 14px 0 0;
                font-size: 16px;
                color: #6a6f7d;
                line-height: 1.6;
            }

        .pp-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .pp-card {
            background: #fff;
            border: 1px solid #ebeaf1;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 1px 2px rgba(40,40,70,0.04);
        }

        .pp-card-icon {
            width: 54px;
            height: 54px;
            border-radius: 16px;
            background: var(--accent-soft);
            display: grid;
            place-items: center;
            font-size: 26px;
        }

        .pp-card h3 {
            margin: 18px 0 8px;
            font-size: 19px;
            font-weight: 700;
            color: #2b2f3a;
        }

        .pp-card p {
            margin: 0;
            font-size: 14px;
            color: #6a6f7d;
            line-height: 1.6;
            min-height: 66px;
        }

        .pp-card-price {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid #f0eff5;
            display: flex;
            align-items: baseline;
            gap: 6px;
        }

            .pp-card-price .amount {
                font-family: Newsreader, serif;
                font-size: 26px;
                font-weight: 600;
                color: var(--accent-ink);
            }

            .pp-card-price .period {
                font-size: 13px;
                color: #9a9eaa;
                font-weight: 600;
            }

        /* How it works */
        .pp-how {
            scroll-margin-top: 80px;
            background: #fbfaf7;
            border-top: 1px solid #efeef4;
            border-bottom: 1px solid #efeef4;
        }

        .pp-how-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 80px 28px;
        }

        .pp-how-hdr {
            text-align: center;
            max-width: 560px;
            margin: 0 auto 48px;
        }

            .pp-how-hdr h2 {
                margin: 0;
                font-family: Newsreader, serif;
                font-size: 38px;
                font-weight: 500;
                letter-spacing: -0.01em;
            }

        .pp-steps {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .pp-step {
            text-align: center;
            padding: 0 12px;
        }

        .pp-step-num {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--accent);
            color: #fff;
            display: grid;
            place-items: center;
            font-family: Newsreader, serif;
            font-size: 22px;
            margin: 0 auto;
        }

        .pp-step h3 {
            margin: 18px 0 8px;
            font-size: 18px;
            font-weight: 700;
        }

        .pp-step p {
            margin: 0;
            font-size: 14px;
            color: #6a6f7d;
            line-height: 1.6;
        }

        /* Contact */
        .pp-contact {
            scroll-margin-top: 80px;
            max-width: 1120px;
            margin: 0 auto;
            padding: 80px 28px;
        }

        .pp-contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 48px;
            align-items: start;
        }

        .pp-contact-info h2 {
            margin: 0 0 16px;
            font-family: Newsreader, serif;
            font-size: 38px;
            font-weight: 500;
            letter-spacing: -0.01em;
        }

        .pp-contact-info > p {
            margin: 0 0 28px;
            font-size: 16px;
            color: #6a6f7d;
            line-height: 1.6;
        }

        .pp-contact-details {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .pp-contact-item {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .pp-contact-item-icon {
            width: 44px;
            height: 44px;
            border-radius: 13px;
            background: var(--accent-soft);
            display: grid;
            place-items: center;
            font-size: 19px;
            flex-shrink: 0;
        }

        .pp-contact-item-label {
            display: block;
            font-size: 12px;
            color: #9a9eaa;
            font-weight: 600;
        }

        .pp-contact-item-value {
            display: block;
            font-size: 15px;
            font-weight: 600;
        }

        .pp-contact-form {
            background: #fff;
            border: 1px solid #ebeaf1;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 1px 2px rgba(40,40,70,0.04);
        }

        .pp-form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .pp-form-field {
            display: block;
        }

            .pp-form-field + .pp-form-field,
            .pp-form-row + .pp-form-field {
                margin-top: 14px;
            }

        .pp-form-label {
            display: block;
            font-size: 12px;
            font-weight: 700;
            color: #6b7280;
            margin-bottom: 6px;
        }

        .pp-form-input,
        .pp-form-textarea {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #e4e2ec;
            border-radius: 10px;
            font: inherit;
            font-size: 14px;
            color: #2b2f3a;
        }

        .pp-form-textarea {
            resize: vertical;
        }

        .pp-btn-submit {
            margin-top: 18px;
            width: 100%;
            padding: 13px;
            border-radius: 11px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            font-family: inherit;
        }

        /* Stats strip */
        .pp-stats {
            background: #fff;
            border-bottom: 1px solid #efeef4;
        }

        .pp-stats-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 36px 28px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            text-align: center;
        }

        .pp-stat-item {
            padding: 8px 0;
        }

        .pp-stat-num {
            display: block;
            font-family: Newsreader, serif;
            font-size: 36px;
            font-weight: 600;
            color: var(--accent-ink);
        }

        .pp-stat-label {
            display: block;
            font-size: 13px;
            color: #9a9eaa;
            font-weight: 600;
            margin-top: 4px;
        }

        /* Testimonials */
        .pp-testimonials {
            background: #fbfaf7;
            border-top: 1px solid #efeef4;
            border-bottom: 1px solid #efeef4;
        }

        .pp-testimonials-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 80px 28px;
        }

        .pp-testimonial-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 44px;
        }

        .pp-testimonial {
            background: #fff;
            border: 1px solid #ebeaf1;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 1px 2px rgba(40,40,70,0.04);
            display: flex;
            flex-direction: column;
        }

        .pp-stars {
            color: #f59e0b;
            font-size: 15px;
            letter-spacing: 2px;
            margin-bottom: 14px;
        }

        .pp-testimonial-text {
            margin: 0 0 20px;
            font-size: 14px;
            color: #4a4f5d;
            line-height: 1.7;
            flex: 1;
        }

        .pp-testimonial-author {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .pp-author-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--accent-soft);
            color: var(--accent-ink);
            display: grid;
            place-items: center;
            font-weight: 700;
            font-size: 14px;
            flex-shrink: 0;
        }

        .pp-author-name {
            display: block;
            font-size: 14px;
            font-weight: 700;
            color: #2b2f3a;
        }

        .pp-author-pet {
            display: block;
            font-size: 12px;
            color: #9a9eaa;
        }

        /* FAQ */
        .pp-faq {
            scroll-margin-top: 80px;
            max-width: 1120px;
            margin: 0 auto;
            padding: 80px 28px;
        }

        .pp-faq-list {
            margin-top: 44px;
            max-width: 720px;
            margin-left: auto;
            margin-right: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .pp-faq-item {
            background: #fff;
            border: 1px solid #ebeaf1;
            border-radius: 14px;
            overflow: hidden;
        }

        .pp-faq-q {
            width: 100%;
            background: none;
            border: none;
            text-align: left;
            padding: 18px 22px;
            font: inherit;
            font-size: 15px;
            font-weight: 700;
            color: #2b2f3a;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

            .pp-faq-q:hover { background: #fafafa; }

        .pp-faq-icon {
            font-size: 22px;
            font-weight: 300;
            color: #9a9eaa;
            flex-shrink: 0;
            transition: transform 0.2s ease;
            line-height: 1;
        }

        .pp-faq-item.open .pp-faq-icon { transform: rotate(45deg); }

        .pp-faq-a {
            display: none;
            padding: 0 22px 18px;
            font-size: 14px;
            color: #6a6f7d;
            line-height: 1.7;
            border-top: 1px solid #f0eff5;
        }

        .pp-faq-item.open .pp-faq-a { display: block; }

        /* Footer */
        .pp-footer {
            background: #2b2f3a;
        }

        .pp-footer-grid {
            max-width: 1120px;
            margin: 0 auto;
            padding: 56px 28px 40px;
            display: grid;
            grid-template-columns: 1.4fr 1fr 1fr;
            gap: 48px;
        }

        .pp-footer-logo {
            display: flex;
            align-items: center;
            gap: 11px;
        }

        .pp-footer-logo-icon {
            width: 36px;
            height: 36px;
            border-radius: 11px;
            background: var(--accent);
            color: #fff;
            display: grid;
            place-items: center;
            font-size: 18px;
        }

        .pp-footer-logo-name {
            font-family: Newsreader, serif;
            font-size: 17px;
            font-weight: 600;
            color: #fff;
        }

        .pp-footer-desc {
            margin: 14px 0 0;
            font-size: 13px;
            color: #8a8fa0;
            line-height: 1.6;
        }

        .pp-footer-col-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #6a6f7d;
            margin: 0 0 16px;
        }

        .pp-footer-links {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

            .pp-footer-links a {
                color: #8a8fa0;
                text-decoration: none;
                font-size: 14px;
            }

            .pp-footer-links a:hover { color: #fff; }

        .pp-footer-contact-item {
            font-size: 13px;
            color: #8a8fa0;
            line-height: 1.5;
            margin-bottom: 14px;
        }

            .pp-footer-contact-item strong {
                display: block;
                color: #6a6f7d;
                font-size: 11px;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                margin-bottom: 3px;
            }

        .pp-footer-bottom {
            border-top: 1px solid #3a3f4e;
            max-width: 1120px;
            margin: 0 auto;
            padding: 20px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 13px;
            color: #8a8fa0;
        }
    </style>
}

<!-- ═══ HEADER ═══ -->
<header class="pp-header">
    <div class="pp-header-inner">
        <a href="@Url.Action("Index", "Home")" class="pp-logo-btn" style="text-decoration:none;">
            <span class="pp-logo-icon">&#x1F43E;</span>
            <span class="pp-logo-text">
                <span class="pp-logo-name">Pawesome Palace</span>
                <span class="pp-logo-sub">Pet Boarding</span>
            </span>
        </a>
        <nav class="pp-nav">
            <a href="#services">Services</a>
            <a href="#reviews">Reviews</a>
            <a href="#how">How it works</a>
            <a href="#faq">FAQ</a>
            <a href="#contact">Contact</a>
        </nav>
        <div class="pp-header-actions">
            @if (Request.IsAuthenticated)
            {
                if (User.IsInRole("Admin"))
                {
                    <a href="@Url.Action("Index", "Admin")" class="pp-btn-ghost">Admin Dashboard</a>
                }
                else
                {
                    <a href="@Url.Action("Index", "MyAccount")" class="pp-btn-ghost">My Account</a>
                }
                using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { style = "display:inline;" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="pp-btn-accent">Sign out</button>
                }
            }
            else
            {
                <a href="@Url.Action("Login", "Account")" class="pp-btn-ghost">Sign in</a>
                <a href="@Url.Action("Register", "Account")" class="pp-btn-accent">Get Started</a>
            }
        </div>
    </div>
</header>

<!-- ═══ HERO ═══ -->
<section class="pp-hero">
    <div class="pp-hero-inner">
        <div class="pp-hero-copy">
            <span class="pp-hero-badge">&#x1F43E; Trusted by 2,000+ pet parents</span>
            <h1 class="pp-hero-h1">A home away from home for your best friend.</h1>
            <p class="pp-hero-lead">Cozy boarding, attentive daycare, and daily photo updates so you can travel knowing they're loved and looked after.</p>
            <div class="pp-hero-ctas">
                @if (Request.IsAuthenticated)
                {
                    <a href="@Url.Action("Create", "Bookings")" class="pp-btn-primary">Book a stay</a>
                }
                else
                {
                    <a href="@Url.Action("Register", "Account")" class="pp-btn-primary">Book a stay</a>
                }
                <a href="#services" class="pp-btn-outline">Explore services</a>
            </div>
