@model PawesomePalace.ViewModels.AdminBookingDetailViewModel
@{
    Layout = null;
    ViewBag.Title = "Booking Detail";

    string statusBg, statusColor;
    switch (Model.Status)
    {
        case "Confirmed":  statusBg = "#e8edfb"; statusColor = "#41509a"; break;
        case "CheckedIn":  statusBg = "#dff0e8"; statusColor = "#2f7a56"; break;
        case "Completed":  statusBg = "#e3f2e9"; statusColor = "#37794f"; break;
        case "Pending":    statusBg = "#fef3dc"; statusColor = "#9a6a1e"; break;
        case "Cancelled":  statusBg = "#f7e4e3"; statusColor = "#a8514a"; break;
        default:           statusBg = "#f3f4f8"; statusColor = "#6a6f7d"; break;
    }
    string fieldStyle = "width: 100%; padding: 10px 13px; border: 1px solid #e4e2ec; border-radius: 10px; font: inherit; font-size: 14px; background: #fff; color: #2b2f3a;";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Booking Detail &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        select:focus, textarea:focus { outline: none; border-color: #6b7fd1; box-shadow: 0 0 0 3px #eef0fb; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">

    <header style="position: sticky; top: 0; z-index: 40; background: #2b2f3a;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 14px 28px; display: flex; align-items: center; gap: 28px;">
            <div style="display: flex; align-items: center; gap: 11px;">
                <span style="width: 38px; height: 38px; border-radius: 12px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 19px;">&#x1F43E;</span>
                <span style="line-height: 1.05;">
                    <span style="display: block; font-family: Newsreader, serif; font-size: 18px; font-weight: 600; color: #fff;">Pawesome Palace</span>
                    <span style="display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8fa0; font-weight: 600;">Staff console</span>
                </span>
            </div>
            <nav style="display: flex; gap: 6px; margin-left: 8px; flex-wrap: wrap;">
                <a href="@Url.Action("Index",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Dashboard</a>
                <a href="@Url.Action("Schedule", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Schedule</a>
                <a href="@Url.Action("Bookings", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: rgba(255,255,255,0.14); color: #fff; text-decoration: none;">Bookings</a>
                <a href="@Url.Action("Pets",     "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Pets</a>
                <a href="@Url.Action("Services", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Services</a>
                <a href="@Url.Action("Contacts", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Contacts</a>
                <a href="@Url.Action("Users",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Users</a>
            </nav>
            <a href="@Url.Action("Index", "Home")" style="margin-left: auto; padding: 8px 15px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: #fff; font-weight: 700; font-size: 13px; text-decoration: none;">Exit console</a>
        </div>
    </header>

    <main style="max-width: 1120px; margin: 0 auto; padding: 36px 28px 80px;">
        <div style="animation: ppFade 0.34s ease both;">

            <a href="@Url.Action("Bookings", "Admin")" style="display: inline-block; color: #9a9eaa; font-size: 14px; font-weight: 600; margin-bottom: 16px; text-decoration: none;">&#x2190; Back to bookings</a>
            <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 24px;">
                <h1 style="margin: 0; font-family: Newsreader, serif; font-size: 28px; font-weight: 500;">@Model.BookingReference</h1>
                <span style="background: @statusBg; color: @statusColor; font-size: 12px; font-weight: 700; padding: 5px 12px; border-radius: 20px;">@Model.Status</span>
            </div>

            <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 20px;">

                <!-- Left: booking info + status controls -->
                <div style="display: flex; flex-direction: column; gap: 16px;">

                    <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; padding: 24px;">
                        <p style="margin: 0 0 14px; font-size: 12px; font-weight: 700; color: #8a8e9b; letter-spacing: 0.06em;">BOOKING INFO</p>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #f0eff5; border: 1px solid #f0eff5; border-radius: 12px; overflow: hidden;">
                            <div style="background:#fff; padding:14px 16px;">
                                <span style="display:block; font-size:12px; color:#9a9eaa; font-weight:600;">Owner</span>
                                <span style="display:block; font-size:15px; font-weight:600; margin-top:3px;">@Model.OwnerName</span>
                            </div>
                            <div style="background:#fff; padding:14px 16px;">
                                <span style="display:block; font-size:12px; color:#9a9eaa; font-weight:600;">Phone</span>
                                <span style="display:block; font-size:15px; font-weight:600; margin-top:3px;">@(string.IsNullOrWhiteSpace(Model.OwnerPhone) ? "-" : Model.OwnerPhone)</span>
                            </div>
                            <div style="background:#fff; padding:14px 16px;">
                                <span style="display:block; font-size:12px; color:#9a9eaa; font-weight:600;">Service</span>
                                <span style="display:block; font-size:15px; font-weight:600; margin-top:3px;">@Model.ServiceType</span>
                            </div>
                            <div style="background:#fff; padding:14px 16px;">
                                <span style="display:block; font-size:12px; color:#9a9eaa; font-weight:600;">Price</span>
                                <span style="display:block; font-size:15px; font-weight:600; margin-top:3px;">@Model.Price.ToString("C")</span>
                            </div>
                            <div style="background:#fff; padding:14px 16px;">
                                <span style="display:block; font-size:12px; color:#9a9eaa; font-weight:600;">Drop-off</span>
                                <span style="display:block; font-size:15px; font-weight:600; margin-top:3px;">@Model.StartDate.ToString("MMM d, yyyy") @Model.DropOffTime</span>
                            </div>
                            <div style="background:#fff; padding:14px 16px;">
                                <span style="display:block; font-size:12px; color:#9a9eaa; font-weight:600;">Pick-up</span>
                                <span style="display:block; font-size:15px; font-weight:600; margin-top:3px;">@Model.EndDate.ToString("MMM d, yyyy") @Model.PickUpTime</span>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.Notes))
                        {
                            <div style="margin-top: 14px; padding: 14px 16px; background: #fbfaf7; border: 1px solid #f0eff5; border-radius: 10px;">
                                <span style="display:block; font-size:12px; color:#9a9eaa; font-weight:600; margin-bottom:4px;">Customer notes</span>
                                <span style="font-size:14px; color:#4a4e5a; line-height:1.5;">@Model.Notes</span>
                            </div>
                        }
                    </div>

                    <!-- Status override -->
                    <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; padding: 24px;">
                        <p style="margin: 0 0 14px; font-size: 12px; font-weight: 700; color: #8a8e9b; letter-spacing: 0.06em;">UPDATE STATUS</p>
                        @using (Html.BeginForm("UpdateBookingStatus", "Admin", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId" value="@Model.BookingId" />
                            <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                                @foreach (var s in new[] { "Pending", "Confirmed", "CheckedIn", "Completed", "Cancelled", "Flagged" })
                                {
                                    <button type="submit" name="newStatus" value="@s"
                                            style="padding: 9px 16px; border-radius: 9px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit;
                                                   @(Model.Status == s ? "background: #2b2f3a; color: #fff; border: none;" : "background: #fff; color: #6a6f7d; border: 1px solid #dcdbe6;")">
                                        @s
                                    </button>
                                }
                            </div>
                        }
                    </div>

                </div>

                <!-- Right: pet care card -->
                <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; padding: 24px; align-self: start;">
                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
                        <span style="width: 40px; height: 40px; border-radius: 12px; background: var(--accent-soft); color: var(--accent-ink); display: grid; place-items: center; font-size: 20px;">&#x1F43E;</span>
                        <div>
                            <p style="margin: 0; font-size: 15px; font-weight: 700;">@Model.PetName</p>
                            <p style="margin: 0; font-size: 13px; color: #9a9eaa;">
                                @Model.PetSpecies
                                @if (!string.IsNullOrWhiteSpace(Model.PetBreed)) { <text>&middot; @Model.PetBreed</text> }
                                @if (!string.IsNullOrWhiteSpace(Model.PetSex)) { <text>&middot; @Model.PetSex</text> }
                            </p>
                        </div>
                        <a href="@Url.Action("PetDetail", "Admin", new { petId = Model.PetId })" style="margin-left: auto; font-size: 13px; font-weight: 600; color: var(--accent-ink); text-decoration: none;">Full profile &#x2192;</a>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.VetName))
                    {
                        <div style="padding: 12px 14px; background: #f9f8fc; border-radius: 10px; margin-bottom: 10px;">
                            <span style="display:block; font-size:11px; color:#9a9eaa; font-weight:700; margin-bottom:3px;">VETERINARIAN</span>
                            <span style="font-size:14px; font-weight:600;">@Model.VetName</span>
                            @if (!string.IsNullOrWhiteSpace(Model.VetPhone)) { <span style="font-size:13px; color:#6a6f7d;"> &middot; @Model.VetPhone</span> }
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.MedicalNotes) || !string.IsNullOrWhiteSpace(Model.Medication))
                    {
                        <div style="padding: 12px 14px; background: #fef3dc; border: 1px solid #f5e3b0; border-radius: 10px; margin-bottom: 10px;">
                            <span style="display:block; font-size:11px; color:#9a6a1e; font-weight:700; margin-bottom:4px;">MEDICAL</span>
                            @if (!string.IsNullOrWhiteSpace(Model.MedicalNotes))
                            {
                                <p style="margin:0 0 4px; font-size:13px; color:#4a4e5a;">@Model.MedicalNotes</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Medication))
                            {
                                <p style="margin:0; font-size:13px; color:#4a4e5a;"><strong>Medication:</strong> @Model.Medication</p>
                            }
                        </div>
                    }

                    <div style="padding: 12px 14px; background: #f9f8fc; border-radius: 10px; margin-bottom: 10px;">
                        <span style="display:block; font-size:11px; color:#9a9eaa; font-weight:700; margin-bottom:4px;">FEEDING</span>
                        <p style="margin:0; font-size:13px; color:#4a4e5a;">
                            @Model.FeedingsPerDay x/day
                            @if (!string.IsNullOrWhiteSpace(Model.FeedAmount)) { <text>&middot; @Model.FeedAmount</text> }
                        </p>
                        @if (!string.IsNullOrWhiteSpace(Model.FeedingInstructions))
                        {
                            <p style="margin:4px 0 0; font-size:13px; color:#6a6f7d;">@Model.FeedingInstructions</p>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.SpecialInstructions))
                    {
                        <div style="padding: 12px 14px; background: #f9f8fc; border-radius: 10px;">
                            <span style="display:block; font-size:11px; color:#9a9eaa; font-weight:700; margin-bottom:4px;">SPECIAL INSTRUCTIONS</span>
                            <p style="margin:0; font-size:13px; color:#4a4e5a;">@Model.SpecialInstructions</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>
</div>
</body>
</html>
