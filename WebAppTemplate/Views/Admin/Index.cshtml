@model PawesomePalace.ViewModels.AdminDashboardViewModel
@{
    Layout = null;
    ViewBag.Title = "Admin dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin dashboard &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">

    <header style="position: sticky; top: 0; z-index: 40; background: #2b2f3a;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 14px 28px; display: flex; align-items: center; gap: 28px;">
            <div style="display: flex; align-items: center; gap: 11px;">
                <span style="width: 38px; height: 38px; border-radius: 12px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 19px;">&#x1F43E;</span>
                <span style="line-height: 1.05;">
                    <span style="display: block; font-family: Newsreader, serif; font-size: 18px; font-weight: 600; color: #fff;">Pawesome Palace</span>
                    <span style="display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8fa0; font-weight: 600;">Staff console</span>
                </span>
            </div>
            <nav style="display: flex; gap: 6px; margin-left: 8px;">
                <a href="@Url.Action("Index", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; font-family: inherit; background: rgba(255,255,255,0.14); color: #fff; text-decoration: none;">Dashboard</a>
                <a href="@Url.Action("Users", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; font-family: inherit; background: transparent; color: rgb(154,160,178); text-decoration: none;">Users</a>
            </nav>
            <a href="@Url.Action("Index", "Home")" style="margin-left: auto; padding: 8px 15px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: #fff; font-weight: 700; font-size: 13px; font-family: inherit; text-decoration: none;">Exit console</a>
        </div>
    </header>

    <main style="max-width: 1120px; margin: 0 auto; padding: 36px 28px 80px;">
        <div style="animation: ppFade 0.34s ease both;">

            <p style="margin: 0 0 6px; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-ink); font-weight: 700;">Staff console</p>
            <h1 style="margin: 0 0 24px; font-family: Newsreader, serif; font-size: 34px; font-weight: 500;">Dashboard</h1>

            <div style="display: flex; gap: 16px; margin-bottom: 24px;">
                <div style="flex: 1; background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; padding: 20px 22px;">
                    <span style="display: block; font-size: 13px; color: #9a9eaa; font-weight: 600;">Pending bookings</span>
                    <span style="display: block; font-family: Newsreader, serif; font-size: 36px; font-weight: 500; margin-top: 4px; color: #9a6a1e;">@Model.PendingCount</span>
                </div>
                <div style="flex: 1; background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; padding: 20px 22px;">
                    <span style="display: block; font-size: 13px; color: #9a9eaa; font-weight: 600;">Confirmed bookings</span>
                    <span style="display: block; font-family: Newsreader, serif; font-size: 36px; font-weight: 500; margin-top: 4px; color: #37794f;">@Model.ConfirmedCount</span>
                </div>
                <div style="flex: 1; background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; padding: 20px 22px;">
                    <span style="display: block; font-size: 13px; color: #9a9eaa; font-weight: 600;">Cancellation requests</span>
                    <span style="display: block; font-family: Newsreader, serif; font-size: 36px; font-weight: 500; margin-top: 4px; color: #a85c2e;">@Model.CancellationRequestCount</span>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px;">

                <div>
                    <p style="margin: 0 0 12px; font-size: 13px; font-weight: 700; color: #8a8e9b; letter-spacing: 0.04em;">PENDING BOOKINGS</p>
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        @if (!Model.PendingBookings.Any())
                        {
                            <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 14px; padding: 24px; text-align: center; color: #9a9eaa; font-size: 14px; font-weight: 600;">
                                No pending bookings.
                            </div>
                        }
                        @foreach (var b in Model.PendingBookings)
                        {
                            string dateDisplay;
                            if (b.StartDate.Date == b.EndDate.Date)
                            {
                                dateDisplay = b.StartDate.ToString("MMM d, yyyy");
                            }
                            else
                            {
                                dateDisplay = b.StartDate.ToString("MMM d") + " - " + b.EndDate.ToString("MMM d, yyyy");
                            }
                            string petInfo = b.PetName
                                + (!string.IsNullOrWhiteSpace(b.PetSpecies) ? " · " + b.PetSpecies : "")
                                + (!string.IsNullOrWhiteSpace(b.PetBreed) ? " · " + b.PetBreed : "");

                            <a href="@Url.Action("Review", "Admin", new { bookingId = b.BookingId })" style="text-align: left; background: #fff; border: 1px solid #ebeaf1; border-radius: 14px; padding: 15px 18px; display: flex; align-items: center; gap: 14px; text-decoration: none;">
                                <span style="width: 44px; height: 44px; border-radius: 13px; background: var(--accent-soft); color: var(--accent-ink); display: grid; place-items: center; font-size: 21px; flex: 0 0 auto;">&#x1F43E;</span>
                                <span style="flex: 1; min-width: 0;">
                                    <span style="display: block; font-size: 15px; font-weight: 700; color: #2b2f3a;">@b.OwnerName</span>
                                    <span style="display: block; font-size: 13px; color: #9a9eaa; margin-top: 2px;">@petInfo</span>
                                </span>
                                <span style="text-align: right;">
                                    <span style="display: block; font-size: 13px; color: #6a6f7d; font-weight: 600;">@dateDisplay</span>
                                    <span style="display: block; font-size: 12px; color: var(--accent-ink); font-weight: 700; margin-top: 2px;">Review &#x2192;</span>
                                </span>
                            </a>
                        }
                    </div>
                </div>

                <div>
                    <p style="margin: 0 0 12px; font-size: 13px; font-weight: 700; color: #8a8e9b; letter-spacing: 0.04em;">CANCELLATION REQUESTS</p>
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        @if (!Model.CancellationRequests.Any())
                        {
                            <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 14px; padding: 24px; text-align: center; color: #9a9eaa; font-size: 14px; font-weight: 600;">
                                No cancellation requests.
                            </div>
                        }
                        @foreach (var c in Model.CancellationRequests)
                        {
                            <a href="@Url.Action("ReviewCancellation", "Admin", new { bookingId = c.BookingId })" style="text-align: left; background: #fff; border: 1px solid #ebeaf1; border-radius: 14px; padding: 15px 18px; display: flex; align-items: center; gap: 14px; text-decoration: none;">
                                <span style="width: 44px; height: 44px; border-radius: 13px; background: #fbe9df; color: #a85c2e; display: grid; place-items: center; font-size: 21px; flex: 0 0 auto;">&#x21A9;</span>
                                <span style="flex: 1; min-width: 0;">
                                    <span style="display: block; font-size: 15px; font-weight: 700; color: #2b2f3a;">@c.OwnerName</span>
                                    <span style="display: block; font-size: 13px; color: #9a9eaa; margin-top: 2px;">@c.Price.ToString("C") refund</span>
                                </span>
                            </a>
                        }
                    </div>
                    <div style="display: flex; gap: 10px; margin-top: 16px;">
                        <a href="@Url.Action("Users", "Admin")" style="flex: 1; padding: 11px; border-radius: 11px; border: 1px solid #dcdbe6; background: #fff; color: #2b2f3a; font-weight: 700; font-size: 13px; font-family: inherit; text-decoration: none; text-align: center;">Manage users</a>
                        <a href="@Url.Action("Index", "Hours")" style="flex: 1; padding: 11px; border-radius: 11px; border: 1px solid #dcdbe6; background: #fff; color: #2b2f3a; font-weight: 700; font-size: 13px; font-family: inherit; text-decoration: none; text-align: center;">Manage services</a>
                    </div>
                </div>

            </div>
        </div>
    </main>
</div>
</body>
</html>
