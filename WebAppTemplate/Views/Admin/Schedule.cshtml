@model PawesomePalace.ViewModels.AdminScheduleViewModel
@{
    Layout = null;
    ViewBag.Title = "Schedule";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Schedule &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">

    <header style="position: sticky; top: 0; z-index: 40; background: #2b2f3a;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 14px 28px; display: flex; align-items: center; gap: 28px;">
            <div style="display: flex; align-items: center; gap: 11px;">
                <span style="width: 38px; height: 38px; border-radius: 12px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 19px;">&#x1F43E;</span>
                <span style="line-height: 1.05;">
                    <span style="display: block; font-family: Newsreader, serif; font-size: 18px; font-weight: 600; color: #fff;">Pawesome Palace</span>
                    <span style="display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8fa0; font-weight: 600;">Staff console</span>
                </span>
            </div>
            <nav style="display: flex; gap: 6px; margin-left: 8px; flex-wrap: wrap;">
                <a href="@Url.Action("Index",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Dashboard</a>
                <a href="@Url.Action("Schedule", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: rgba(255,255,255,0.14); color: #fff; text-decoration: none;">Schedule</a>
                <a href="@Url.Action("Bookings", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Bookings</a>
                <a href="@Url.Action("Pets",     "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Pets</a>
                <a href="@Url.Action("Services", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Services</a>
                <a href="@Url.Action("Contacts", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Contacts</a>
                <a href="@Url.Action("Users",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Users</a>
            </nav>
            <a href="@Url.Action("Index", "Home")" style="margin-left: auto; padding: 8px 15px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: #fff; font-weight: 700; font-size: 13px; text-decoration: none;">Exit console</a>
        </div>
    </header>

    <main style="max-width: 1120px; margin: 0 auto; padding: 36px 28px 80px;">
        <div style="animation: ppFade 0.34s ease both;">

            <h1 style="margin: 0 0 20px; font-family: Newsreader, serif; font-size: 34px; font-weight: 500;">Schedule</h1>

            <div style="display: flex; gap: 8px; margin-bottom: 24px;">
                @foreach (var f in new[] { "Today", "ThisWeek", "NextWeek", "All" })
                {
                    var label = f == "ThisWeek" ? "This Week" : f == "NextWeek" ? "Next Week" : f;
                    var active = Model.DateFilter == f;
                    <a href="@Url.Action("Schedule", "Admin", new { filter = f })"
                       style="padding: 9px 18px; border-radius: 10px; font-size: 14px; font-weight: 700; text-decoration: none;
                              @(active ? "background: var(--accent); color: #fff;" : "background: #fff; color: #6a6f7d; border: 1px solid #dcdbe6;")">
                        @label
                    </a>
                }
            </div>

            @if (!Model.Items.Any())
            {
                <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; padding: 48px; text-align: center; color: #9a9eaa; font-size: 15px; font-weight: 600;">
                    No bookings for this period.
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @foreach (var item in Model.Items)
                    {
                        string statusBg, statusColor;
                        switch (item.Status)
                        {
                            case "CheckedIn": statusBg = "#dff0e8"; statusColor = "#2f7a56"; break;
                            case "Confirmed": statusBg = "#e8edfb"; statusColor = "#41509a"; break;
                            default:          statusBg = "#f3f4f8"; statusColor = "#6a6f7d"; break;
                        }
                        <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; padding: 20px 24px; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;">
                            <div>
                                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 6px;">
                                    <span style="font-size: 16px; font-weight: 700;">@item.PetName</span>
                                    @if (!string.IsNullOrWhiteSpace(item.PetSpecies))
                                    {
                                        <span style="font-size: 13px; color: #9a9eaa;">@item.PetSpecies</span>
                                    }
                                    @if (item.MedicalAlert)
                                    {
                                        <span style="background: #fbe9df; color: #a85c2e; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 6px;">MEDICAL</span>
                                    }
                                    <span style="background: @statusBg; color: @statusColor; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 6px;">@item.Status.ToUpper()</span>
                                </div>
                                <div style="font-size: 13px; color: #6a6f7d;">
                                    <strong>@item.OwnerName</strong>
                                    @if (!string.IsNullOrWhiteSpace(item.OwnerPhone)) { <text> &middot; @item.OwnerPhone</text> }
                                    &nbsp;&middot;&nbsp; @item.ServiceType
                                </div>
                                <div style="font-size: 13px; color: #9a9eaa; margin-top: 3px;">
                                    Drop-off: @item.StartDate.ToString("MMM d") @item.DropOffTime
                                    &nbsp;&middot;&nbsp;
                                    Pick-up: @item.EndDate.ToString("MMM d") @item.PickUpTime
                                </div>
                            </div>
                            <div style="display: flex; gap: 8px; align-items: center;">
                                @if (item.Status == "Confirmed")
                                {
                                    using (Html.BeginForm("CheckIn", "Admin", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bookingId" value="@item.BookingId" />
                                        <button type="submit" style="padding: 10px 18px; border-radius: 10px; border: none; background: #4f9d70; color: #fff; font-weight: 700; font-size: 13px; cursor: pointer; font-family: inherit;">Check In</button>
                                    }
                                }
                                else if (item.Status == "CheckedIn")
                                {
                                    using (Html.BeginForm("CheckOut", "Admin", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bookingId" value="@item.BookingId" />
                                        <button type="submit" style="padding: 10px 18px; border-radius: 10px; border: none; background: #6b7fd1; color: #fff; font-weight: 700; font-size: 13px; cursor: pointer; font-family: inherit;">Check Out</button>
                                    }
                                }
                                <a href="@Url.Action("BookingDetail", "Admin", new { bookingId = item.BookingId })" style="padding: 10px 16px; border-radius: 10px; border: 1px solid #dcdbe6; background: #fff; color: #2b2f3a; font-weight: 700; font-size: 13px; text-decoration: none;">Details</a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </main>
</div>
</body>
</html>
