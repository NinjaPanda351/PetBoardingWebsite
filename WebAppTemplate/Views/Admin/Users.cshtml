@model PawesomePalace.ViewModels.AdminUsersViewModel
@{
    Layout = null;
    ViewBag.Title = "Manage users";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin users &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        ::placeholder { color: #aeb2bd; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
        input:focus { outline: none; border-color: #6b7fd1; box-shadow: 0 0 0 3px #eef0fb; }
        .user-row { display: flex; align-items: center; gap: 16px; padding: 16px 20px; border-bottom: 1px solid #f3f2f7; }
        .user-row:last-child { border-bottom: none; }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">

    <header style="position: sticky; top: 0; z-index: 40; background: #2b2f3a;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 14px 28px; display: flex; align-items: center; gap: 28px;">
            <div style="display: flex; align-items: center; gap: 11px;">
                <span style="width: 38px; height: 38px; border-radius: 12px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 19px;">&#x1F43E;</span>
                <span style="line-height: 1.05;">
                    <span style="display: block; font-family: Newsreader, serif; font-size: 18px; font-weight: 600; color: #fff;">Pawesome Palace</span>
                    <span style="display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8fa0; font-weight: 600;">Staff console</span>
                </span>
            </div>
            <nav style="display: flex; gap: 6px; margin-left: 8px; flex-wrap: wrap;">
                <a href="@Url.Action("Index",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Dashboard</a>
                <a href="@Url.Action("Schedule", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Schedule</a>
                <a href="@Url.Action("Bookings", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Bookings</a>
                <a href="@Url.Action("Pets",     "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Pets</a>
                <a href="@Url.Action("Services", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Services</a>
                <a href="@Url.Action("Contacts", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Contacts</a>
                <a href="@Url.Action("Users",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: rgba(255,255,255,0.14); color: #fff; text-decoration: none;">Users</a>
            </nav>
            <a href="@Url.Action("Index", "Home")" style="margin-left: auto; padding: 8px 15px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: #fff; font-weight: 700; font-size: 13px; font-family: inherit; text-decoration: none;">Exit console</a>
        </div>
    </header>

    <main style="max-width: 1120px; margin: 0 auto; padding: 36px 28px 80px;">
        <div style="animation: ppFade 0.34s ease both;">

            <p style="margin: 0 0 6px; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-ink); font-weight: 700;">Staff console</p>
            <h1 style="margin: 0 0 20px; font-family: Newsreader, serif; font-size: 32px; font-weight: 500;">Manage users</h1>

            <input id="searchBox" type="text" placeholder="Search by name or email..."
                   value="@Model.Search"
                   style="width: 100%; max-width: 420px; padding: 12px 16px; border: 1px solid #e4e2ec; border-radius: 12px; font: inherit; font-size: 14px; margin-bottom: 16px; display: block;">

            <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; overflow: hidden;" id="userList">
                @if (!Model.Users.Any())
                {
                    <div style="padding: 32px; text-align: center; color: #9a9eaa; font-size: 14px; font-weight: 600;">No users found.</div>
                }
                @foreach (var u in Model.Users)
                {
                    string badgeBg    = u.IsSuspended ? "#f7e4e3" : "#e3f2e9";
                    string badgeColor = u.IsSuspended ? "#a8514a" : "#37794f";
                    string badgeText  = u.IsSuspended ? "Suspended" : "Active";
                    string petLabel   = u.PetCount == 1 ? "1 pet" : u.PetCount + " pets";

                    <div class="user-row" data-name="@u.FullName.ToLower()" data-email="@u.Email.ToLower()">
                        <span style="width: 40px; height: 40px; border-radius: 50%; background: var(--accent-soft); color: var(--accent-ink); display: grid; place-items: center; font-weight: 800; font-size: 14px; flex: 0 0 auto;">@u.Initials</span>
                        <span style="flex: 1; min-width: 0;">
                            <span style="display: block; font-size: 15px; font-weight: 700; color: #2b2f3a;">@u.FullName</span>
                            <span style="display: block; font-size: 13px; color: #9a9eaa; margin-top: 1px;">@u.Email</span>
                        </span>
                        <span style="font-size: 13px; color: #9a9eaa; width: 70px;">@petLabel</span>
                        <span style="display: inline-block; background: @badgeBg; color: @badgeColor; font-size: 11.5px; font-weight: 700; padding: 4px 10px; border-radius: 20px; white-space: nowrap;">@badgeText</span>
                        <a href="@Url.Action("ViewUser", "Admin", new { ownerId = u.OwnerId })" style="padding: 8px 16px; border-radius: 10px; border: 1px solid #dcdbe6; background: #fff; color: #2b2f3a; font-weight: 700; font-size: 13px; font-family: inherit; text-decoration: none; white-space: nowrap;">View user</a>
                    </div>
                }
            </div>

            <a href="@Url.Action("Index", "Admin")" style="display: inline-block; margin-top: 22px; background: none; border: none; color: #9a9eaa; font-size: 14px; font-weight: 600; cursor: pointer; padding: 0; font-family: inherit; text-decoration: none;">&#x2190; Back to dashboard</a>
        </div>
    </main>
</div>
<script>
    (function () {
        var input = document.getElementById('searchBox');
        var rows = document.querySelectorAll('.user-row');
        input.addEventListener('input', function () {
            var q = input.value.trim().toLowerCase();
            rows.forEach(function (row) {
                var match = !q || row.dataset.name.includes(q) || row.dataset.email.includes(q);
                row.style.display = match ? '' : 'none';
            });
        });
    })();
</script>
</body>
</html>
