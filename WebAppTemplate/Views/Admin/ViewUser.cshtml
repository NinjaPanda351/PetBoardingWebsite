@model PawesomePalace.ViewModels.AdminViewUserViewModel
@{
    Layout = null;
    ViewBag.Title = "User detail";

    string badgeBg    = Model.IsSuspended ? "#f7e4e3" : "#e3f2e9";
    string badgeColor = Model.IsSuspended ? "#a8514a" : "#37794f";
    string badgeText  = Model.IsSuspended ? "Suspended" : "Active";
    string petLabel   = Model.PetCount == 1 ? "1" : Model.PetCount.ToString();

    string fullAddress = string.Join(", ",
        new[] { Model.Address, Model.City, Model.State, Model.ZipCode }
        .Where(s => !string.IsNullOrWhiteSpace(s)));
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>User detail &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">

    <header style="position: sticky; top: 0; z-index: 40; background: #2b2f3a;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 14px 28px; display: flex; align-items: center; gap: 28px;">
            <div style="display: flex; align-items: center; gap: 11px;">
                <span style="width: 38px; height: 38px; border-radius: 12px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 19px;">&#x1F43E;</span>
                <span style="line-height: 1.05;">
                    <span style="display: block; font-family: Newsreader, serif; font-size: 18px; font-weight: 600; color: #fff;">Pawesome Palace</span>
                    <span style="display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8fa0; font-weight: 600;">Staff console</span>
                </span>
            </div>
            <nav style="display: flex; gap: 6px; margin-left: 8px; flex-wrap: wrap;">
                <a href="@Url.Action("Index",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Dashboard</a>
                <a href="@Url.Action("Schedule", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Schedule</a>
                <a href="@Url.Action("Bookings", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Bookings</a>
                <a href="@Url.Action("Pets",     "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Pets</a>
                <a href="@Url.Action("Services", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Services</a>
                <a href="@Url.Action("Contacts", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Contacts</a>
                <a href="@Url.Action("Users",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: rgba(255,255,255,0.14); color: #fff; text-decoration: none;">Users</a>
            </nav>
            <a href="@Url.Action("Index", "Home")" style="margin-left: auto; padding: 8px 15px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: #fff; font-weight: 700; font-size: 13px; font-family: inherit; text-decoration: none;">Exit console</a>
        </div>
    </header>

    <main style="max-width: 1120px; margin: 0 auto; padding: 36px 28px 80px;">
        <div style="animation: ppFade 0.34s ease both; max-width: 600px; margin: 0 auto;">

            <a href="@Url.Action("Users", "Admin")" style="display: inline-block; background: none; border: none; color: #9a9eaa; font-size: 14px; font-weight: 600; cursor: pointer; padding: 0; margin-bottom: 16px; font-family: inherit; text-decoration: none;">&#x2190; Back to users</a>

            <div style="display: flex; flex-direction: column; gap: 16px;">

                <!-- Identity card -->
                <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 18px; padding: 28px; box-shadow: rgba(40,40,70,0.04) 0px 1px 2px;">

                    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 22px;">
                        <span style="width: 56px; height: 56px; border-radius: 50%; background: var(--accent-soft); color: var(--accent-ink); display: grid; place-items: center; font-weight: 800; font-size: 20px; flex: 0 0 auto;">@Model.Initials</span>
                        <div>
                            <h1 style="margin: 0; font-family: Newsreader, serif; font-size: 24px; font-weight: 500;">@Model.FullName</h1>
                            <p style="margin: 3px 0 0; font-size: 13px; color: #9a9eaa;">Member since @Model.MemberSince.ToString("MMM yyyy")</p>
                        </div>
                        <span style="margin-left: auto; display: inline-block; background: @badgeBg; color: @badgeColor; font-size: 12px; font-weight: 700; padding: 5px 12px; border-radius: 20px; white-space: nowrap;">@badgeText</span>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #f0eff5; border: 1px solid #f0eff5; border-radius: 12px; overflow: hidden;">
                        <div style="background: #fff; padding: 16px 18px;">
                            <span style="display: block; font-size: 12px; color: #9a9eaa; font-weight: 600;">Email</span>
                            <span style="display: block; font-size: 15px; font-weight: 600; margin-top: 3px;">@Model.Email</span>
                        </div>
                        <div style="background: #fff; padding: 16px 18px;">
                            <span style="display: block; font-size: 12px; color: #9a9eaa; font-weight: 600;">Phone</span>
                            <span style="display: block; font-size: 15px; font-weight: 600; margin-top: 3px;">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</span>
                        </div>
                        <div style="background: #fff; padding: 16px 18px;">
                            <span style="display: block; font-size: 12px; color: #9a9eaa; font-weight: 600;">Pets on file</span>
                            <span style="display: block; font-size: 15px; font-weight: 600; margin-top: 3px;">@petLabel</span>
                        </div>
                        <div style="background: #fff; padding: 16px 18px;">
                            <span style="display: block; font-size: 12px; color: #9a9eaa; font-weight: 600;">Account status</span>
                            <span style="display: block; font-size: 15px; font-weight: 600; margin-top: 3px; color: @badgeColor;">@badgeText</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(fullAddress))
                        {
                            <div style="background: #fff; padding: 16px 18px; grid-column: 1 / -1;">
                                <span style="display: block; font-size: 12px; color: #9a9eaa; font-weight: 600;">Address</span>
                                <span style="display: block; font-size: 15px; font-weight: 600; margin-top: 3px;">@fullAddress</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Emergency contacts -->
                @if (Model.EmergencyContacts.Any())
                {
                    <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 18px; padding: 24px; box-shadow: rgba(40,40,70,0.04) 0px 1px 2px;">
                        <p style="margin: 0 0 14px; font-size: 12px; font-weight: 700; color: #8a8e9b; letter-spacing: 0.06em;">EMERGENCY CONTACTS</p>
                        <div style="display: flex; flex-direction: column; gap: 8px;">
                            @foreach (var ec in Model.EmergencyContacts)
                            {
                                <div style="padding: 13px 15px; background: #f9f8fc; border-radius: 10px; display: flex; align-items: center; gap: 12px;">
                                    <div style="flex: 1;">
                                        <span style="font-size: 14px; font-weight: 700;">@ec.FirstName @ec.LastName</span>
                                        <span style="font-size: 13px; color: #9a9eaa; margin-left: 8px;">@ec.Relationship</span>
                                    </div>
                                    <span style="font-size: 14px; color: #6a6f7d;">@ec.Phone</span>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>

            <a href="@Url.Action("Users", "Admin")" style="display: inline-block; margin-top: 22px; padding: 11px 20px; border-radius: 11px; border: 1px solid #dcdbe6; background: #fff; color: #2b2f3a; font-weight: 700; font-size: 14px; font-family: inherit; text-decoration: none;">&#x2190; Back to users</a>

        </div>
    </main>
</div>
</body>
</html>
