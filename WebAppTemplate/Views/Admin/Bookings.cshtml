@model PawesomePalace.ViewModels.AdminBookingsListViewModel
@{
    Layout = null;
    ViewBag.Title = "Bookings";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bookings &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
        input[type=text]:focus { outline: none; border-color: #6b7fd1; box-shadow: 0 0 0 3px #eef0fb; }
        table { width: 100%; border-collapse: collapse; }
        th { font-size: 12px; font-weight: 700; color: #8a8e9b; letter-spacing: 0.06em; text-align: left; padding: 14px 16px 10px; }
        td { padding: 14px 16px; border-top: 1px solid #f0eff5; font-size: 14px; vertical-align: middle; }
        tr:hover td { background: #fafafe; }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">

    <header style="position: sticky; top: 0; z-index: 40; background: #2b2f3a;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 14px 28px; display: flex; align-items: center; gap: 28px;">
            <div style="display: flex; align-items: center; gap: 11px;">
                <span style="width: 38px; height: 38px; border-radius: 12px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 19px;">&#x1F43E;</span>
                <span style="line-height: 1.05;">
                    <span style="display: block; font-family: Newsreader, serif; font-size: 18px; font-weight: 600; color: #fff;">Pawesome Palace</span>
                    <span style="display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8fa0; font-weight: 600;">Staff console</span>
                </span>
            </div>
            <nav style="display: flex; gap: 6px; margin-left: 8px; flex-wrap: wrap;">
                <a href="@Url.Action("Index",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Dashboard</a>
                <a href="@Url.Action("Schedule", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Schedule</a>
                <a href="@Url.Action("Bookings", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: rgba(255,255,255,0.14); color: #fff; text-decoration: none;">Bookings</a>
                <a href="@Url.Action("Pets",     "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Pets</a>
                <a href="@Url.Action("Services", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Services</a>
                <a href="@Url.Action("Contacts", "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Contacts</a>
                <a href="@Url.Action("Users",    "Admin")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; background: transparent; color: rgb(154,160,178); text-decoration: none;">Users</a>
            </nav>
            <a href="@Url.Action("Index", "Home")" style="margin-left: auto; padding: 8px 15px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.2); background: transparent; color: #fff; font-weight: 700; font-size: 13px; text-decoration: none;">Exit console</a>
        </div>
    </header>

    <main style="max-width: 1120px; margin: 0 auto; padding: 36px 28px 80px;">
        <div style="animation: ppFade 0.34s ease both;">

            <h1 style="margin: 0 0 20px; font-family: Newsreader, serif; font-size: 34px; font-weight: 500;">Bookings</h1>

            <!-- Filters -->
            <div style="display: flex; gap: 10px; margin-bottom: 16px; align-items: center; flex-wrap: wrap;">
                @foreach (var s in new[] { "All", "Pending", "Confirmed", "CheckedIn", "Completed", "Cancelled", "Flagged" })
                {
                    var active = Model.StatusFilter == s;
                    <a href="@Url.Action("Bookings", "Admin", new { status = s, search = Model.Search })"
                       style="padding: 8px 14px; border-radius: 9px; font-size: 13px; font-weight: 700; text-decoration: none;
                              @(active ? "background: var(--accent); color: #fff;" : "background: #fff; color: #6a6f7d; border: 1px solid #dcdbe6;")">
                        @s
                    </a>
                }
                @using (Html.BeginForm("Bookings", "Admin", FormMethod.Get, new { style = "display:flex; gap:8px; margin-left:auto;" }))
                {
                    <input type="hidden" name="status" value="@Model.StatusFilter" />
                    <input type="text" name="search" value="@Model.Search" placeholder="Search owner, pet, ref..."
                           style="padding: 9px 14px; border: 1px solid #dcdbe6; border-radius: 9px; font-size: 14px; font-family: inherit; width: 220px;" />
                    <button type="submit" style="padding: 9px 16px; border-radius: 9px; border: none; background: var(--accent); color: #fff; font-weight: 700; font-size: 13px; cursor: pointer; font-family: inherit;">Search</button>
                }
            </div>

            <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 16px; overflow: hidden;">
                @if (!Model.Items.Any())
                {
                    <div style="padding: 48px; text-align: center; color: #9a9eaa; font-size: 15px; font-weight: 600;">No bookings found.</div>
                }
                else
                {
                    <table>
                        <thead><tr>
                            <th>Reference</th>
                            <th>Owner</th>
                            <th>Pet</th>
                            <th>Service</th>
                            <th>Dates</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th></th>
                        </tr></thead>
                        <tbody>
                            @foreach (var b in Model.Items)
                            {
                                string sBg, sColor;
                                switch (b.Status)
                                {
                                    case "Confirmed":  sBg = "#e8edfb"; sColor = "#41509a"; break;
                                    case "CheckedIn":  sBg = "#dff0e8"; sColor = "#2f7a56"; break;
                                    case "Completed":  sBg = "#e3f2e9"; sColor = "#37794f"; break;
                                    case "Pending":    sBg = "#fef3dc"; sColor = "#9a6a1e"; break;
                                    case "Cancelled":  sBg = "#f7e4e3"; sColor = "#a8514a"; break;
                                    default:           sBg = "#f3f4f8"; sColor = "#6a6f7d"; break;
                                }
                                <tr>
                                    <td style="font-family: monospace; font-size: 13px;">@b.BookingReference</td>
                                    <td style="font-weight: 600;">@b.OwnerName</td>
                                    <td>@b.PetName</td>
                                    <td>@b.ServiceType</td>
                                    <td style="font-size: 13px; color: #6a6f7d;">
                                        @b.StartDate.ToString("MMM d") &ndash; @b.EndDate.ToString("MMM d, yyyy")
                                    </td>
                                    <td style="font-weight: 600;">@b.Price.ToString("C")</td>
                                    <td><span style="background: @sBg; color: @sColor; font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 6px;">@b.Status</span></td>
                                    <td><a href="@Url.Action("BookingDetail", "Admin", new { bookingId = b.BookingId })" style="font-size: 13px; font-weight: 600; color: var(--accent-ink); text-decoration: none;">View &#x2192;</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

        </div>
    </main>
</div>
</body>
</html>
