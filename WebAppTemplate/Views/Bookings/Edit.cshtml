@model PawesomePalace.ViewModels.EditBookingViewModel
@{
    Layout = null;
    ViewBag.Title = "Edit booking";
    ViewBag.ActiveNav = "Bookings";

    string fieldStyle = "width: 100%; padding: 11px 14px; border: 1px solid #e4e2ec; border-radius: 10px; font: inherit; font-size: 14px; background: #fff; color: #2b2f3a;";
    string labelStyle = "display: block; font-size: 12px; font-weight: 700; color: #6b7280; margin-bottom: 6px;";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edit booking &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        ::placeholder { color: #aeb2bd; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
        input:focus, select:focus, textarea:focus { outline: none; border-color: #6b7fd1; box-shadow: 0 0 0 3px #eef0fb; }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">
    @Html.Partial("_PpHeader")
    <main style="max-width: 1120px; margin: 0px auto; padding: 36px 28px 80px;">
        <div style="animation: ppFade 0.34s ease both; max-width: 600px; margin: 0px auto;">
            <a href="@Url.Action("Details", "Bookings", new { bookingId = Model.BookingId })" style="display: inline-block; background: none; border: none; color: #9a9eaa; font-size: 14px; font-weight: 600; cursor: pointer; padding: 0px; margin-bottom: 16px; font-family: inherit; text-decoration: none;">&#x2190; Back</a>
            <h1 style="margin: 0px 0px 4px; font-family: Newsreader, serif; font-size: 28px; font-weight: 500;">Edit booking</h1>
            <p style="margin: 0px 0px 20px; font-size: 13px; color: #9a9eaa;">@Model.BookingReference &middot; pending changes are re-reviewed by our team</p>

            @using (Html.BeginForm("Edit", "Bookings", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.BookingId)
                @Html.HiddenFor(m => m.BookingReference)

                <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 18px; padding: 28px; box-shadow: rgba(40, 40, 70, 0.04) 0px 1px 2px;">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">

                        <label style="display: block;">
                            <span style="@labelStyle">Start date</span>
                            @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}", new { type = "date", style = fieldStyle })
                        </label>

                        <label style="display: block;">
                            <span style="@labelStyle">End date</span>
                            @Html.TextBoxFor(m => m.EndDate, "{0:yyyy-MM-dd}", new { type = "date", style = fieldStyle })
                        </label>

                        <label style="display: block;">
                            <span style="@labelStyle">Drop-off time</span>
                            @Html.TextBoxFor(m => m.DropOffTime, new { type = "time", style = fieldStyle })
                        </label>

                        <label style="display: block;">
                            <span style="@labelStyle">Pick-up time</span>
                            @Html.TextBoxFor(m => m.PickUpTime, new { type = "time", style = fieldStyle })
                        </label>

                    </div>

                    <label style="display: block; margin-top: 16px;">
                        <span style="@labelStyle">Special instructions</span>
                        @Html.TextAreaFor(m => m.SpecialInstructions, 3, 0, new { placeholder = "Feeding schedule, medication, comfort items...", style = fieldStyle })
                    </label>

                    <div style="margin-top: 22px; display: flex; align-items: center; gap: 12px;">
                        <button type="submit" style="padding: 12px 22px; border-radius: 11px; border: none; background: var(--accent); color: #fff; font-weight: 700; font-size: 14px; cursor: pointer; font-family: inherit;">Save changes</button>
                        <a href="@Url.Action("Details", "Bookings", new { bookingId = Model.BookingId })" style="padding: 12px 20px; border-radius: 11px; border: 1px solid #dcdbe6; background: #fff; color: #2b2f3a; font-weight: 700; font-size: 14px; cursor: pointer; font-family: inherit; text-decoration: none; display: inline-flex; align-items: center;">Cancel</a>
                        <a href="@Url.Action("CancelRequest", "Bookings", new { bookingId = Model.BookingId })" style="margin-left: auto; padding: 12px 18px; border-radius: 11px; border: 1px solid #ecd9d9; background: #fff; color: #b4564f; font-weight: 700; font-size: 14px; cursor: pointer; font-family: inherit; text-decoration: none; display: inline-flex; align-items: center;">Request cancellation</a>
                    </div>
                </div>
            }
        </div>
    </main>
</div>
</body>
</html>
