@model PawesomePalace.ViewModels.MyAccountViewModel
@{
    Layout = null;
    ViewBag.Title = "Profile";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Profile &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        ::placeholder { color: #aeb2bd; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
        input:focus, select:focus, textarea:focus { outline: none; border-color: #6b7fd1; box-shadow: 0 0 0 3px #eef0fb; }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">

    <!-- HEADER -->
    <header style="position: sticky; top: 0; z-index: 40; background: rgba(255,255,255,0.86); backdrop-filter: blur(10px); border-bottom: 1px solid #e7e6ee;">
        <div style="max-width: 1120px; margin: 0 auto; padding: 14px 28px; display: flex; align-items: center; gap: 28px;">
            <a href="@Url.Action("Index", "Home")" style="display: flex; align-items: center; gap: 11px; text-decoration: none;">
                <span style="width: 38px; height: 38px; border-radius: 12px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 19px; box-shadow: 0 4px 12px -3px var(--accent);">&#x1F43E;</span>
                <span style="text-align: left; line-height: 1.05;">
                    <span style="display: block; font-family: Newsreader, serif; font-size: 18px; font-weight: 600; color: #2b2f3a;">Pawesome Palace</span>
                    <span style="display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #9a9eaa; font-weight: 600;">Pet Boarding</span>
                </span>
            </a>
            <nav style="display: flex; gap: 6px; margin-left: 8px;">
                <a href="@Url.Action("Index", "MyAccount")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; font-family: inherit; background: var(--accent-soft); color: var(--accent-ink); text-decoration: none;">Profile</a>
                <a href="@Url.Action("Index", "Pets")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; font-family: inherit; background: transparent; color: #7a7f8c; text-decoration: none;">My Pets</a>
                <a href="@Url.Action("Index", "Bookings")" style="padding: 8px 15px; border-radius: 10px; font-size: 14px; font-weight: 700; font-family: inherit; background: transparent; color: #7a7f8c; text-decoration: none;">Bookings</a>
            </nav>
            <div style="margin-left: auto; display: flex; align-items: center; gap: 11px;">
                <span style="text-align: right; line-height: 1.1;">
                    <span style="display: block; font-size: 13px; font-weight: 700; color: #2b2f3a;">@Model.FullName</span>
                    <span style="display: block; font-size: 11px; color: #9a9eaa;">Pet parent</span>
                </span>
                <span style="width: 36px; height: 36px; border-radius: 50%; background: var(--accent-soft); color: var(--accent-ink); display: grid; place-items: center; font-weight: 800; font-size: 14px;">@Model.Initials</span>
            </div>
        </div>
    </header>

    <!-- MAIN -->
    <main style="max-width: 1120px; margin: 0 auto; padding: 36px 28px 80px;">
        <div style="animation: ppFade 0.34s ease both;">
            <div style="display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 26px;">
                <div>
                    <p style="margin: 0 0 6px; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-ink); font-weight: 700;">Your account</p>
                    <h1 style="margin: 0; font-family: Newsreader, serif; font-size: 36px; font-weight: 500; letter-spacing: -0.01em;">Welcome back, @Model.FirstName</h1>
                </div>
                <a href="@Url.Action("Index", "Manage")" style="padding: 11px 18px; border-radius: 11px; border: 1px solid #dcdbe6; background: #fff; color: #2b2f3a; font-weight: 700; font-size: 14px; text-decoration: none;">Edit profile</a>
            </div>

            <div style="display: grid; grid-template-columns: 1.1fr 1fr; gap: 20px;">

                <!-- Contact card -->
                <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 18px; padding: 26px 28px; box-shadow: rgba(40,40,70,0.04) 0px 1px 2px;">
                    <p style="margin: 0 0 18px; font-size: 13px; font-weight: 700; color: #8a8e9b; letter-spacing: 0.04em;">CONTACT DETAILS</p>
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        <div style="display: flex; align-items: center; gap: 14px;">
                            <span style="width: 42px; height: 42px; border-radius: 12px; background: var(--accent-soft); display: grid; place-items: center; font-size: 18px;">&#x1F464;</span>
                            <span>
                                <span style="display: block; font-size: 12px; color: #9a9eaa; font-weight: 600;">Full name</span>
                                <span style="display: block; font-size: 16px; font-weight: 600;">@Model.FullName</span>
                            </span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 14px;">
                            <span style="width: 42px; height: 42px; border-radius: 12px; background: var(--accent-soft); display: grid; place-items: center; font-size: 18px;">&#x2709;&#xFE0F;</span>
                            <span>
                                <span style="display: block; font-size: 12px; color: #9a9eaa; font-weight: 600;">Email</span>
                                <span style="display: block; font-size: 16px; font-weight: 600;">@Model.Email</span>
                            </span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 14px;">
                            <span style="width: 42px; height: 42px; border-radius: 12px; background: var(--accent-soft); display: grid; place-items: center; font-size: 18px;">&#x1F4DE;</span>
                            <span>
                                <span style="display: block; font-size: 12px; color: #9a9eaa; font-weight: 600;">Phone</span>
                                <span style="display: block; font-size: 16px; font-weight: 600;">@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</span>
                            </span>
                        </div>
                    </div>
                    <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid #f0eff5; display: flex; gap: 10px;">
                        @using (Html.BeginForm("LogOff", "Account", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" style="padding: 10px 16px; border-radius: 10px; border: 1px solid #ecd9d9; background: #fff; color: #b4564f; font-weight: 700; font-size: 13px; cursor: pointer; font-family: inherit;">Log out</button>
                        }
                        <button style="padding: 10px 16px; border-radius: 10px; border: none; background: none; color: #b0b3bd; font-weight: 600; font-size: 13px; cursor: pointer; font-family: inherit;">Delete account</button>
                    </div>
                </div>

                <!-- Right column -->
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    <a href="@Url.Action("Index", "Pets")" style="text-align: left; background: #fff; border: 1px solid #ebeaf1; border-radius: 18px; padding: 22px 24px; display: flex; align-items: center; gap: 16px; box-shadow: rgba(40,40,70,0.04) 0px 1px 2px; text-decoration: none;">
                        <span style="width: 46px; height: 46px; border-radius: 13px; background: #fbecdf; display: grid; place-items: center; font-size: 22px;">&#x1F436;</span>
                        <span style="flex: 1;">
                            <span style="display: block; font-size: 16px; font-weight: 700; color: #2b2f3a;">Manage pets</span>
                            <span style="display: block; font-size: 13px; color: #9a9eaa; margin-top: 2px;">@Model.PetCount pet@(Model.PetCount == 1 ? "" : "s") on file</span>
                        </span>
                        <span style="color: var(--accent); font-size: 20px;">&#x2192;</span>
                    </a>
                    <a href="@Url.Action("Index", "Bookings")" style="text-align: left; background: #fff; border: 1px solid #ebeaf1; border-radius: 18px; padding: 22px 24px; display: flex; align-items: center; gap: 16px; box-shadow: rgba(40,40,70,0.04) 0px 1px 2px; text-decoration: none;">
                        <span style="width: 46px; height: 46px; border-radius: 13px; background: var(--accent-soft); display: grid; place-items: center; font-size: 22px;">&#x1F4C5;</span>
                        <span style="flex: 1;">
                            <span style="display: block; font-size: 16px; font-weight: 700; color: #2b2f3a;">Manage bookings</span>
                            <span style="display: block; font-size: 13px; color: #9a9eaa; margin-top: 2px;">@Model.ActiveBookingCount active stay@(Model.ActiveBookingCount == 1 ? "" : "s")</span>
                        </span>
                        <span style="color: var(--accent); font-size: 20px;">&#x2192;</span>
                    </a>
                    <div style="background: linear-gradient(135deg, var(--accent), var(--accent-ink)); border-radius: 18px; padding: 22px 24px; color: #fff;">
                        <p style="margin: 0 0 4px; font-size: 13px; opacity: 0.85; font-weight: 600;">Ready for a getaway?</p>
                        <p style="margin: 0 0 14px; font-family: Newsreader, serif; font-size: 20px;">Book a cozy stay for your pet.</p>
                        <a href="@Url.Action("Create", "Bookings")" style="display: inline-block; padding: 9px 16px; border-radius: 10px; background: #fff; color: var(--accent-ink); font-weight: 700; font-size: 13px; text-decoration: none;">Request a booking</a>
                    </div>
                </div>

            </div>
        </div>
    </main>
</div>
</body>
</html>
