@model PawesomePalace.Models.RegisterViewModel
@{
    Layout = null;
    ViewBag.Title = "Create account";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Create account &middot; Pawesome Palace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: #2b2f3a; background: #f3f4f8; -webkit-font-smoothing: antialiased; }
        ::placeholder { color: #aeb2bd; }
        @@keyframes ppFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
        input:focus, select:focus, textarea:focus { outline: none; border-color: #6b7fd1; box-shadow: 0 0 0 3px #eef0fb; }
        .field-validation-error { display: block; font-size: 12px; color: #d9534f; margin-top: 4px; }
        .validation-summary-errors ul { margin: 0; padding: 0 0 0 16px; font-size: 13px; color: #d9534f; }
    </style>
</head>
<body>
<div style="min-height: 100vh; --accent: #6b7fd1; --accent-soft: #eef0fb; --accent-ink: #41509a;">
    <div style="min-height: 100vh; display: grid; place-items: center; padding: 44px 20px; background: linear-gradient(165deg, var(--accent-soft), #f3f4f8 62%);">
        <div style="width: 100%; max-width: 440px; animation: ppFade 0.34s ease both;">
            <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 22px;">
                <span style="width: 54px; height: 54px; border-radius: 16px; background: var(--accent); color: #fff; display: grid; place-items: center; font-size: 27px; box-shadow: 0 8px 22px -6px var(--accent);">&#x1F43E;</span>
                <span style="font-family: Newsreader, serif; font-size: 23px; font-weight: 600; margin-top: 12px;">Pawesome Palace</span>
                <span style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #9a9eaa; font-weight: 600;">Pet Boarding</span>
            </div>
            <div style="background: #fff; border: 1px solid #ebeaf1; border-radius: 20px; padding: 30px; box-shadow: rgba(40,40,70,0.3) 0px 14px 36px -20px;">
                <h1 style="margin: 0 0 4px; font-family: Newsreader, serif; font-size: 24px; font-weight: 500;">Create your account</h1>
                <p style="margin: 0 0 22px; font-size: 14px; color: #9a9eaa;">Join Pawesome Palace in a couple of steps.</p>

                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px;">
                        <label style="display: block;">
                            <span style="display: block; font-size: 12px; font-weight: 700; color: #6b7280; margin-bottom: 6px;">First name</span>
                            @Html.TextBoxFor(m => m.FirstName, new { placeholder = "John", style = "width: 100%; padding: 12px 14px; border: 1px solid #e4e2ec; border-radius: 10px; font: inherit; font-size: 14px; color: #2b2f3a;" })
                            @Html.ValidationMessageFor(m => m.FirstName)
                        </label>
                        <label style="display: block;">
                            <span style="display: block; font-size: 12px; font-weight: 700; color: #6b7280; margin-bottom: 6px;">Last name</span>
                            @Html.TextBoxFor(m => m.LastName, new { placeholder = "Doe", style = "width: 100%; padding: 12px 14px; border: 1px solid #e4e2ec; border-radius: 10px; font: inherit; font-size: 14px; color: #2b2f3a;" })
                            @Html.ValidationMessageFor(m => m.LastName)
                        </label>
                    </div>

                    <label style="display: block; margin-top: 14px;">
                        <span style="display: block; font-size: 12px; font-weight: 700; color: #6b7280; margin-bottom: 6px;">Email address</span>
                        @Html.TextBoxFor(m => m.Email, new { type = "email", placeholder = "you@email.com", style = "width: 100%; padding: 12px 14px; border: 1px solid #e4e2ec; border-radius: 10px; font: inherit; font-size: 14px; color: #2b2f3a;" })
                        @Html.ValidationMessageFor(m => m.Email)
                    </label>

                    <label style="display: block; margin-top: 14px;">
                        <span style="display: block; font-size: 12px; font-weight: 700; color: #6b7280; margin-bottom: 6px;">Phone number</span>
                        @Html.TextBoxFor(m => m.Phone, new { type = "tel", placeholder = "(XXX) XXX-XXXX", style = "width: 100%; padding: 12px 14px; border: 1px solid #e4e2ec; border-radius: 10px; font: inherit; font-size: 14px; color: #2b2f3a;" })
                        @Html.ValidationMessageFor(m => m.Phone)
                    </label>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 14px;">
                        <label style="display: block;">
                            <span style="display: block; font-size: 12px; font-weight: 700; color: #6b7280; margin-bottom: 6px;">Password</span>
                            @Html.PasswordFor(m => m.Password, new { placeholder = "&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;", style = "width: 100%; padding: 12px 14px; border: 1px solid #e4e2ec; border-radius: 10px; font: inherit; font-size: 14px; color: #2b2f3a;" })
                            @Html.ValidationMessageFor(m => m.Password)
                        </label>
                        <label style="display: block;">
                            <span style="display: block; font-size: 12px; font-weight: 700; color: #6b7280; margin-bottom: 6px;">Confirm</span>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { placeholder = "&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;", style = "width: 100%; padding: 12px 14px; border: 1px solid #e4e2ec; border-radius: 10px; font: inherit; font-size: 14px; color: #2b2f3a;" })
                            @Html.ValidationMessageFor(m => m.ConfirmPassword)
                        </label>
                    </div>

                    <label style="display: flex; align-items: center; gap: 9px; cursor: pointer; font-size: 13px; color: #6a6f7d; font-weight: 600; margin: 18px 0 20px;">
                        <input type="checkbox" style="width: 16px; height: 16px; accent-color: var(--accent);">
                        I agree to the Terms of Service &amp; Privacy Policy
                    </label>

                    <button type="submit" style="width: 100%; padding: 13px; border-radius: 11px; border: none; background: var(--accent); color: #fff; font-weight: 700; font-size: 15px; cursor: pointer; font-family: inherit;">Create account</button>
                }

                <p style="margin: 18px 0 0; text-align: center; font-size: 14px; color: #9a9eaa;">
                    Already have an account? @Html.ActionLink("Sign in", "Login", "Account", null, new { style = "color: var(--accent-ink); font-weight: 700; text-decoration: none;" })
                </p>
            </div>
        </div>
    </div>
</div>
</body>
</html>
